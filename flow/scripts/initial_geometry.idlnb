                "   1.2700378e+08   1.3931466e+08   1.5109558e+08   1.5607869e+08   1.7347630e+08",
                "   1.7960510e+08   1.7740970e+08   1.7162434e+08   1.6170186e+08   1.4991589e+08",
                "   1.4955307e+08   1.4413262e+08   1.4832930e+08   1.4449870e+08   1.4264696e+08",
                "   1.4518947e+08   1.5353426e+08   1.6501501e+08   1.8011274e+08   1.7457859e+08",
                "   1.8796904e+08   2.4573141e+08   2.3943576e+08   2.7336800e+08   2.6171632e+08",
