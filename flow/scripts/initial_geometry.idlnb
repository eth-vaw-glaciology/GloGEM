{
  "version": "2.0.0",
  "cells": [
    {
      "type": "markdown",
      "content": [
        "### initial_geometry"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        ".compile load_glacier"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "% Compiled module: LOAD_GLACIER."
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "; define necessary parameters",
        "aflow = 1e-16           ; X = value of deformation-sliding factor (10^-16 Pa^-3 a^-1)",
        "dt_flag = 0             ; 0 = adaptive time step (dynamic); X = time step in years",
        "display_during_flag = 1 ; 0 = do not display anything during run (geometry and smb stuff); 1 = display during run --> may be useful for debugging/checks (is normally not used)",
        "width_flag = 2          ; 0 = same width along the flowline (never used, may even not work anymore; was used for initial tests); 1 = rectangle transect (only used for sensitivity tests in paper); 2 = trapezium transect (classic)",
        "dtfactor = 1            ; X = multiply dt by a certain factor --> can be used to avoid numerical instability",
        "start_year = 0          ; X = year in which the simulation starts (typically 0 for steady state experiments, and real year (e.g. 1950/1990) for transient simulations)",
        "flag_startobs = 1       ; 0 = start from zero ice thickness; 1 = start from observed geometry (at RGI inventory date); 2 = start from modelled geometry",
        "nyears = 5000           ; X = number of years for simulation (will stop earlier if steady state is reached, if numerical instability occurred, if ice is leaving the domain, or if there is no ice)"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; load glacier data",
        "result = load_glacier('01450', 'centraleurope', 0, 1.0/4.0, 0)",
        "dx = result.dx",
        "sur_input = result.sur_input",
        "th_input = result.th_input",
        "width_input = result.width_input",
        "length_fixeddistance = result.length_fixeddistance",
        "x_input = result.x_input"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "dx =          202",
                "volume_Huss_1d =    1.2761819e+10",
                "volume_Huss_1d_fixeddistance =    1.2907665e+10",
                "area_Huss_1d =        82165000.",
                "area_Huss_1d_fixeddistance =        82722555.",
                ""
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "; load necessary constants",
        "@constants_counters_initialvalues_sizevariables"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "for i = 0, xnum - 1 do begin",
        "    if th_input[i] gt 0 then begin",
        "      first_icp = i",
        "      break",
        "    endif",
        "  endfor"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; ; Observed volume per grid and surface elevation",
        "x = fltarr(xnum)",
        "obs_vol = fltarr(xnum)",
        "obs_sur = fltarr(xnum)",
        "for i = 0, xnum - 1 do begin",
        "  x[i] = ((i + 1) / float(xnum)) * domainsize",
        "  obs_vol[i] = th_input[i] * width_input[i] * dx",
        "  obs_sur[i] = sur_input[i] ; In some cases 'obs_sur' is needed for SMB calculations (when this is based on observed geometry and not on modelled geometry)",
        "endfor",
        "obs_vol_flowlinemodel = total(obs_vol) ; can be slightly different than 'volume_Huss_1d_fixeddistance', because of very slight smoothing at the end of 'load_glacier'",
        "print, 'obs_vol_flowlinemodel = ', obs_vol_flowlinemodel"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "obs_vol_flowlinemodel =   1.29400e+10"
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "; ; Observed surface width",
        "width_surface = fltarr(xnum)",
        "if width_flag eq 1 or width_flag eq 2 then begin ; Rectangle or trapezium",
        "  for i = 0, xnum - 1 do begin",
        "    width_surface[i] = width_input[i]",
        "    if width_surface[i] eq 0 then begin",
        "      width_surface[i] = mean(width_input[first_icp : first_icp + 10]) ; For pre-frontal region: impose the average surface width of 10 lowest glacier covered cells",
        "    endif",
        "  endfor",
        "endif"
      ],
      "metadata": {},
      "outputs": []
    },
