                "      -1.0751842     -0.99219376     -0.90039033     -0.80721271     -0.72751415",
                "     -0.66279769     -0.59708244     -0.51961774     -0.43099841     -0.34429935",
                "     -0.23788318     -0.10371085     0.068407074      0.24041116      0.39754075",
                "      0.52683347      0.64003360      0.74706292      0.87938803       1.0192651",
                "       1.1691651       1.3042455       1.4356272       1.5498129       1.6556215",
