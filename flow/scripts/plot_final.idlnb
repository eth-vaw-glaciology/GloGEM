        "; Add axes labels and title",
        "base_plot.xtitle = 'Distance (km)'",
        "base_plot.ytitle = 'Elevation (km)'",
        "base_plot.title = 'Year ' + string(floor(time_hist[i]), format = '(I0)')",
        "base_plot.font_size = 18",
        "l.font_size = 14"
