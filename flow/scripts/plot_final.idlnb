    {
      "type": "code",
      "content": [
        "i = 0",
        "",
        "; Create a properly sized window with reasonable dimensions",
        "w1 = window(dimensions = [1000, 800], margin=[0.12, 0.12, 0.12, 0.07], $",
        "  background_color='white')",
        "",
        "; Set up the layout based on display flag",
        "if display_end_flag ge 5 then begin",
        "  ; Main layout for glacier plot",
        "  pos1 = [0.1, 0.1, 0.65, 0.9] ; Left, bottom, right, top in normalized coordinates",
        "endif else begin",
        "  pos1 = [0.15, 0.1, 0.9, 0.9] ; More generous margins",
        "endelse",
        "",
        "; Calculate the vertical range needed for the plot",
        "surface_data = bed + th_hist[i, *]",
        "ymin = min(bed)",
        "ymax = max(surface_data)",
        "xmin = min(x / 1000) ; Normalized x range minimum",
        "xmax = max(x / 1000) ; Normalized x range maximum",
        "",
        "; First create a base plot to define the coordinate system",
        "base_plot = plot(x/1000, bed, /nodata, $",
        "  xrange=[xmin, xmax], yrange=[ymin, ymax], $",
        "  /current, color='white')",
        "",
        "; DRAW BEDROCK FIRST",
        "bed_min = min(bed)  ; Add some extra space below",
        "bedrock_x = [x / 1000, reverse(x / 1000)]",
        "bedrock_y = [bed, replicate(bed_min, n_elements(bed))]",
        "p1 = polygon(bedrock_x, bedrock_y, /fill_background, $",
        "  fill_color = [240, 240, 240], target = w1, $",
        "  /data, NAME = 'bedrock')",
        "",
        "; THEN DRAW GLACIER using the exact same bed coordinates",
        "glacier_x = [x / 1000, reverse(x / 1000)]",
        "glacier_y = [bed, reverse(surface_data)]  ; Uses the same bed array!",
        "p2 = polygon(glacier_x, glacier_y, /fill_background, $",
        "  fill_color = [0, 204, 255], target = w1, $",
        "  /data)",
        "",
        "; Draw the glacier surface in the same window",
        "p3 = plot(x / 1000, obs_sur, '--' ,color='black', $",
        "  thick=2, /data, NAME = 'Observed glacier surface (in ' + string(inventory_date_id, format = '(I0)') + ')', $",
        "  /overplot)",
        "",
        "; Add legend",
        "l = legend(target = [p3], /device, position = [650,650], /normal, /auto_text_color)",
        "",
        "; Add axes labels and title",
        "base_plot.xtitle = 'Distance (km)'",
        "base_plot.ytitle = 'Elevation (km)'",
        "base_plot.title = 'Year ' + string(floor(time_hist[i]), format = '(I0)')",
        "base_plot.font_size = 18",
        "l.font_size = 14"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":1000,\"ysize\":800,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "i = 216",
        "",
        "; Create a properly sized window with reasonable dimensions",
        "w1 = window(dimensions = [1000, 800], margin=[0.12, 0.12, 0.12, 0.07], $",
        "  background_color='white')",
        "",
        "; Set up the layout based on display flag",
        "if display_end_flag ge 5 then begin",
        "  ; Main layout for glacier plot",
        "  pos1 = [0.1, 0.1, 0.65, 0.9] ; Left, bottom, right, top in normalized coordinates",
        "endif else begin",
        "  pos1 = [0.15, 0.1, 0.9, 0.9] ; More generous margins",
        "endelse",
        "",
        "; Calculate the vertical range needed for the plot",
        "surface_data = bed + th_hist[i, *]",
        "ymin = min(bed)",
        "ymax = max(surface_data)",
        "xmin = min(x / 1000) ; Normalized x range minimum",
        "xmax = max(x / 1000) ; Normalized x range maximum",
        "",
        "; First create a base plot to define the coordinate system",
        "base_plot = plot(x/1000, bed, /nodata, $",
        "  xrange=[xmin, xmax], yrange=[ymin, ymax], $",
        "  /current, color='white')",
        "",
        "; DRAW BEDROCK FIRST",
        "bed_min = min(bed)  ; Add some extra space below",
        "bedrock_x = [x / 1000, reverse(x / 1000)]",
        "bedrock_y = [bed, replicate(bed_min, n_elements(bed))]",
        "p1 = polygon(bedrock_x, bedrock_y, /fill_background, $",
        "  fill_color = [240, 240, 240], target = w1, $",
        "  /data, NAME = 'bedrock')",
        "",
        "; THEN DRAW GLACIER using the exact same bed coordinates",
        "glacier_x = [x / 1000, reverse(x / 1000)]",
        "glacier_y = [bed, reverse(surface_data)]  ; Uses the same bed array!",
        "p2 = polygon(glacier_x, glacier_y, /fill_background, $",
        "  fill_color = [0, 204, 255], target = w1, $",
        "  /data)",
        "",
        "; Draw the glacier surface in the same window",
        "p3 = plot(x / 1000, obs_sur, '--' ,color='black', $",
        "  thick=2, /data, NAME = 'Observed glacier surface (in ' + string(inventory_date_id, format = '(I0)') + ')', $",
        "  /overplot)",
