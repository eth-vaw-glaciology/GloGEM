    },
    {
      "type": "code",
      "content": [
        "i = 216",
        "",
        "; Add additional subplots if needed",
        "if display_end_flag ge 5 then begin",
        "",
        "  ; Create a new window for the subplots",
        "  w2 = window(dimensions = [800, 800], margin=[0.12, 0.12, 0.12, 0.07], $",
        "    background_color='white')",
        "  ",
        "  ; Plot volume history",
        "  p4 = plot(time_hist[0 : i], vol_hist[0 : i], 'black', thick = 2, $",
        "    yrange = [min(vol_hist[0 : counter_diag - 1]) * 0.98, max(vol_hist[0 : counter_diag - 1]) * 1.02], $",
        "    xrange = [start_year, time], /current, margin = [0.1, 0.1, 0.1, 0.1])",
        "  p4.xtitle = 'Time (a)'",
        "  p4.ytitle = 'Volume (km³)'",
        "  p4.font_size = 14",
        "  ",
        "  ; Create second y axis for SMB",
        "  p5 = plot(time_hist[0 : i], bal_mean_hist[0 : i], 'red', thick = 2, $",
        "    yrange = [min(bal_mean_hist[0 : counter_diag - 1]) * 0.98, max(bal_mean_hist[0 : counter_diag - 1]) * 1.02], $",
        "    /overplot)",
        "  p5.font_size = 14",
        "  ax2 = axis('Y', location = 'right', target = p5, color = 'red', $",
        "    title = 'SMB (m i.e. a⁻¹)')",
        "    ",
        "  ; Create a 2nd window for the smb and flux divergence subplot",
        "  w3 = window(dimensions = [800, 800], margin=[0.12, 0.12, 0.12, 0.07], $",
        "    background_color='white')",
        "  ",
        "  ; Plot SMB",
        "  p6 = plot(x[1 : xnum - 2] / 1000, bal_hist[i, 1 : xnum - 2], 'blue', thick = 2, $",
        "    yrange = [min(bal_hist), max(bal_hist)], $",
        "    xrange = [dx, (domainsize - dx)] / 1000, /current)",
        "  p6.xtitle = 'Distance (km)'",
        "  p6.ytitle = 'SMB (m i.e a⁻¹)'",
        "  p6.font_size = 14",
        "  ",
        "  ; Plot flux divergence on second y-axis",
        "  p7 = plot(x[1 : xnum - 2] / 1000, -fluxdiv_plot_hist[i, 1 : xnum - 2], color='red', '--', /overplot)",
        "  p7.font_size = 14",
        "  ax3 = axis('Y', location = 'right', target = p7, color = 'red', $",
        "    title = '- Flux div. (m a⁻¹)')",
        "endif"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":800,\"ysize\":800,\"data\":\"\"}}"
