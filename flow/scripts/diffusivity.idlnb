                "       149.78971654431621       124.58683265009529       104.78464888197932",
                "       101.73428846235826       105.61171458911180       124.42322401932809",
                "       138.65954554992746       139.01764668511842       122.53793912799422",
                "       102.51429888929005       95.336961998781632       89.891299241027710",
