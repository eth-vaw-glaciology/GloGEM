      "type": "code",
      "content": [
        "w2 = window(dimensions = [800, 600])",
        "p2 = plot(indgen(n_elements(grad)), grad, /current, $",
        "    title = 'Surface Gradient', $",
        "    xtitle = 'Grid Index', ytitle = 'Surface Gradient', $",
        "    xrange = [0, n_elements(grad) - 1], $",
