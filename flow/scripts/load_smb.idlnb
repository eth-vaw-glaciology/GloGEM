    {
      "type": "code",
      "content": [
        "; ; Generate a second-order elevation-dependent fit through these points:",
        "; Best SMB mean fit (2nd order, i.e. parabola) over the 1960-1990 period:",
        "fit_order2_smb_mean = poly_fit(mb_obsrcm[*, 0], mean_mb, 2)",
        "; Best SMB fit (2nd order, i.e. parabola) for every individual year",
        "fit_order2_smb = fltarr(columns - 1, 3)",
        "for i = 0, columns - 2 do begin",
        "  fit_order2_smb[i, *] = poly_fit(mb_obsrcm[*, 0], mb_obsrcm[*, i + 1], 2)",
        "endfor"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; Plot the second-order elevation-dependent fit",
        "window, /free, xsize = 800, ysize = 600, title = 'Second-Order Fit Plot'",
        "p2 = plot(mb_obsrcm[*, 0], mean_mb, title = 'Second-Order Fit of Mean SMB', xtitle = 'Elevation', ytitle = 'Mean SMB (m i.e. a⁻¹)', color = 'blue', thick = 2, NAME='Data')",
        "p3 = plot(mb_obsrcm[*, 0], fit_order2_smb_mean[0] + fit_order2_smb_mean[1] * mb_obsrcm[*, 0] + fit_order2_smb_mean[2] * mb_obsrcm[*, 0]^2, color = 'red', thick = 2, /OVERPLOT, NAME='Fit')",
        "; Add legend to the plot",
        "leg = LEGEND(TARGET=[p2,p3], /DATA, /AUTO_TExt_COLOR, position=[4200,0])"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
