{
  "version": "2.0.0",
  "cells": [
    {
      "type": "markdown",
      "content": [
        "### load_smb",
        "",
        "IDL notebook to test functionality of load_smb script."
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        ".compile import_glacier_smb",
        ".compile load_glacier"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "% Compiled module: IMPORT_GLACIER_SMB.",
                "% Compiled module: LOAD_GLACIER."
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "; some necessary constants",
        "rho = 900 ; Density of ice in kg/m^3"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; Define all parameters individually",
        "aflow = 1e-16              ; X = value of deformation-sliding factor (10^-16 Pa^-3 a^-1)",
        "calibration_method = 0     ; 0 = no calibration; 1 = 1990 steady state; 2 = 1950 steady state",
        "dx = 0                     ; 0 = resolution chosen to divide glacier into 100 grid cells; X = resolution (m)",
        "display_during_flag = 1    ; 0 = no display during run; 1 = display during run",
        "display_end_flag = 0       ; 0 = no display at end; 1 = save final figure; 2-6 = various movie options",
        "dtfactor = 1               ; X = multiply dt by a factor to avoid numerical instability",
        "dt_flag = 0                ; 0 = adaptive time step; X = fixed time step in years",
        "flag_startobs = 1          ; 0 = start from zero ice thickness; 1 = start from observed geometry; 2 = start from modeled geometry",
        "frontal_length = 1.0/4.0   ; X = length of proglacial area as fraction of glacier length",
        "mb_bias_flag = 0           ; 0 = no bias; 'on' = impose mb bias; X = bias applied on SMB field",
        "mb_sur_flag = 1            ; 0 = SMB based on observed geometry; 1 = dynamic SMB based on prognostic geometry",
        "mb_type_flag = 5           ; 1-6 = various SMB calculation methods",
        "nyears = 5000              ; X = number of years for simulation",
        "smb_sinus_flag = 0         ; 0 = no sinusoidal perturbation; X = sinusoidal signal frequency in years",
        "ss_criterion = 0.01        ; X = steady state criterion as percent volume change per year",
        "start_year = 0             ; X = simulation start year",
        "width_flag = 2             ; 0 = same width; 1 = rectangle transect; 2 = trapezium transect",
        ""
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "glacier_id = '01450'",
        "region = 'centraleurope'",
        "chain = 1"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "@geom_files_load_and_transform"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "dx =          202",
                "volume_Huss_1d =    1.2761819e+10",
                "volume_Huss_1d_fixeddistance =    1.2907665e+10",
                "area_Huss_1d =        82165000.",
                "area_Huss_1d_fixeddistance =        82722555.",
                ""
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "@constants_counters_initialvalues_sizevariables"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "@initial_geometry"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "obs_vol_flowlinemodel =   1.29400e+10",
                "obs_vol_trapezium =   1.29400e+10",
                ""
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "; getting the directory of the current script",
        "routine_path = routine_filepath()",
        "current_dir = file_dirname(routine_path)"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; load glacier data",
        "result = load_glacier('01450', 'centraleurope', 0, 1.0/4.0, 0)",
        "dx = result.dx",
        "sur_input = result.sur_input",
        "th_input = result.th_input",
        "width_input = result.width_input",
        "length_fixeddistance = result.length_fixeddistance",
        "x_input = result.x_input"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "dx =          202",
                "volume_Huss_1d =    1.2761819e+10",
                "volume_Huss_1d_fixeddistance =    1.2907665e+10",
                "area_Huss_1d =        82165000.",
                "area_Huss_1d_fixeddistance =        82722555.",
                ""
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "if chain le 100 then begin ; chain from EURO-CORDEX ensemble",
        "    mb_obsrcm = import_glacier_smb(current_dir + '/../input/' + region + '/smb_rcm/chain' + string(chain, format = '(I02)') + '/belev_' + string(glacier_id, format = '(I05)') + '.dat') ; SMB as calculated based on OBS/RCM output (data from Matthias)",
        "  endif else begin ; For committed loss experiments: load data from chain01 (because are based on pre-2017 climate, and this is the same in every chain)",
        "    mb_obsrcm = import_glacier_smb(current_dir + '/../input/' + region + '/smb_rcm/chain01/belev_' + string(glacier_id, format = '(I05)') + '.dat') ; SMB as calculated based on OBS/RCM output (data from Matthias)",
        "  endelse"
      ],
      "metadata": {},
      "outputs": []
    },
