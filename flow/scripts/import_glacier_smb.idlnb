{
  "version": "2.0.0",
  "cells": [
    {
      "type": "markdown",
      "content": [
        "### import_glacier_smb"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "  ; getting the directory of the current script",
        "  routine_path = routine_filepath()",
        "  current_dir = file_dirname(routine_path)"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "glacier_id = 01450",
        "chain = 1",
        "chainstr = string(chain, format = '(I02)')",
        "idstr = string(glacier_id, format = '(I05)')",
        "filename = current_dir + '/../input/centraleurope/smb_rcm/chain' + chainstr + '/belev_' + idstr + '.dat'"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "filename"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "/Users/janoschbeer/Library/Mobile Documents/com~apple~CloudDocs/PhD/projects/GloGEM/flow/scripts/../input/centraleurope/smb_rcm/chain01/belev_01450.dat"
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "  ; Initialize variables",
        "  delimiter = ' '",
        "",
        "  ; Set default values for startRow and endRow if not provided",
        "  if n_params() lt 2 then startRow = 1 ; IDL is 0-based but we want to start from header line (1)",
        "  if n_params() lt 3 then endRow = 0 ; 0 means read all rows"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "startRow = 2",
        "endRow = 0"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        " ; Open the file",
        " openr, lun, filename, /get_lun, error = err",
        " if err ne 0 then begin",
        "   message, 'Error opening file: ' + filename",
        "   RETURN, -1",
        " endif",
        ""
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "  ; Skip header lines (startRow-1)",
        "  if startRow gt 1 then begin",
        "    header = ''",
        "    for i = 0, startRow - 2 do begin",
        "      readf, lun, header",
        "    endfor",
        "  endif"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "  ; Read all lines from the file into a string array",
        "  lines = ''",
        "  if endRow gt 0 then begin",
        "    ; Read specified number of rows",
        "    data_lines = strarr(endRow - startRow + 1)",
        "    for i = 0, (endRow - startRow) do begin",
        "      readf, lun, lines",
        "      data_lines[i] = lines",
        "    endfor",
        "  endif else begin",
        "    ; Read all rows until end of file",
        "    data_lines = ''",
        "    while ~eof(lun) do begin",
        "      readf, lun, lines",
        "      data_lines = [data_lines, lines]",
        "    endwhile",
        "",
        "    ; Remove the initial empty entry",
        "    if data_lines[0] eq '' then data_lines = data_lines[1 : *]",
        "  endelse"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "  ; Close the file",
        "  free_lun, lun",
        "",
        "  ; Determine the number of rows and columns",
        "  n_rows = n_elements(data_lines) ; Exclude the header line",
        "",
        "  ; Create a temporary array to hold string values from each line",
        "  temp_values = strsplit(data_lines[0], delimiter, /extract)",
        "  n_cols = n_elements(temp_values)",
        "",
        "  ; Create the output array",
        "  belev = dblarr(n_cols, n_rows)"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "data_lines"
      ],
