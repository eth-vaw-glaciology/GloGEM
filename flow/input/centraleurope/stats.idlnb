{
  "version": "2.0.0",
  "cells": [
    {
      "type": "markdown",
      "content": [
        "### stats"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        ".compile import_glacier_geometry_1d ; needs to be compiled when called in idlnb"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "% Compiled module: IMPORT_GLACIER_GEOMETRY_1D."
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "; getting the directory of the current script",
        "routine_path = ROUTINE_FILEPATH()",
        "script_path = FILE_DIRNAME(routine_path)"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; Close all graphics windows",
        "while (!d.window ne -1) do wdelete",
        "",
        "t_start = systime(/seconds)",
        "",
        "data_glaciers = fltarr(3927, 3)",
        "",
        "; Read RGI data - note: you'll need to create an equivalent import_rgi_data function in IDL",
        "data_rgi = import_rgi_data(script_path + '/rgi/11_rgi60_CentralEurope.csv')",
        "restore, script_path + '/inventory_date.sav'"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "for glacier_id = 1, 3927 do begin ; Range over which geometry files exist",
        "  print, 'Processing glacier ID: ', glacier_id",
        "  ",
        "  ; You'll need to create an equivalent import_glacier_geometry_1d function in IDL",
        "  filename = script_path + string(glacier_id, format = '(\"/flowline_geom/\",I05,\".dat\")')",
        "  glacier_geom = import_glacier_geometry_1d(filename)",
        "  ",
        "  length_array = n_elements(glacier_geom[*, 0])",
        "  data_glaciers[glacier_id - 1, 0] = glacier_geom[length_array - 1, 6] / 1000.0 ; Glacier length (km)",
        "  data_glaciers[glacier_id - 1, 1] = total(glacier_geom[*, 3]) ; Glacier area (km^2)",
        "  ",
        "  vol = 0.0",
        "  for i = 0, length_array - 1 do begin",
        "    vol = vol + glacier_geom[i, 3] * glacier_geom[i, 4] / 1000.0 ; area*thick",
        "  endfor",
        "  ",
        "  data_glaciers[glacier_id - 1, 2] = vol ; Glacier volume (km^3)",
        "  endfor"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
