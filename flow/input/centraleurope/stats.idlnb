        "index_larger_than_1_km3_glaciers = where(data_glaciers[*, 2] gt 1, /null)",
        "index_smaller_than_1_km_glaciers = where(data_glaciers[*, 0] lt 1, /null)",
        "index_2003inventorydate_glaciers = where(inventory_date eq 2003, /null)"
      ],
