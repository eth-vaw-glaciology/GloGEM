{
  "version": "2.0.0",
  "cells": [
    {
      "type": "markdown",
      "content": [
        "# Aletsch Glacier (RGI60-11.01450) — GloGEMflow Sanity Check",
        "",
        "Three-way comparison: **GloGEMflow (SIA, this study)** vs **GloGEM dhdt** vs **Zekollari et al. (2019)**.",
        "",
        "**Expected ranges for Aletsch:**",
        "- Length: ~23 km | Area: ~81 km² | Volume: ~15 km³ at RGI inventory (~2003)",
        "- Max ice thickness: ~800–900 m | Average thickness: ~200 m",
        "- Tongue elevation: ~1560 m | Accumulation zone: ~3500–4100 m",
        "- ELA ~3000–3200 m under recent climate"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "markdown",
      "content": [
        "## 1. Load Data"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "compile_opt idl2",
        "",
        "; --- Scenario to load ---",
        "gcm = 'BCC-CSM2-MR'",
        "rcp = 'ssp585'",
        "",
        "data_dir = 'results_dhdt_vs_flow/r6_monthly/CentralEurope/' + gcm + '/' + rcp + '/'",
        "dhdt_dir = 'results_dhdt_vs_flow/r6_monthly/CentralEurope/'     + gcm + '/' + rcp + '/'",
        "zek_dir  = 'supplement_Zekollari_et_al_TC2019_hz02APR2019/'",
        "",
        "; --- Load GloGEMflow (SIA) results ---",
        "restore, data_dir + 'flowgrid_01450_flow.sav'",
        "fl = flow_hist",
        "",
        "; --- Load GloGEM dhdt results ---",
        "restore, dhdt_dir + 'geometry_01450_dhdt.sav'",
        "dhdt = geometry_hist",
        "",
        "; Handle older dhdt structs that may lack area_total",
        "dhdt_tags = tag_names(dhdt)",
        "if max(dhdt_tags eq 'AREA_TOTAL') eq 0 then begin",
        "  nyears_dhdt = n_elements(dhdt.years)",
        "  dhdt_area_total = dblarr(nyears_dhdt)",
        "  for yy = 0, nyears_dhdt - 1 do $",
        "    dhdt_area_total[yy] = total(dhdt.area[*, yy])",
        "  dhdt = create_struct(dhdt, 'area_total', dhdt_area_total)",
        "  print, 'Note: dhdt area_total reconstructed from per-band areas'",
        "endif",
        "",
        "dist_km = fl.dist_dx / 1000.0",
        "",
        "iy2004 = where(fl.years eq 2004)",
        "iy2020 = where(fl.years eq 2020)",
        "iy2050 = where(fl.years eq 2050)",
        "iy2100 = where(fl.years eq 2100)",
        "",
        "print, '=== Aletsch (01450) — ' + gcm + ' / ' + rcp + ' ==='",
        "print, 'Flow grid: xnum=', fl.xnum, ' dx=', fl.dx, ' m  length=', fl.xnum*fl.dx/1000., ' km'",
        "print, 'Year range: ', min(fl.years), ' to ', max(fl.years)"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "=== Aletsch (01450) — BCC-CSM2-MR / ssp585 ===",
                "Flow grid: xnum=         125 dx=         200 m  length=      25.0000 km",
                "Year range:         1990 to         2100"
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "markdown",
      "content": [
        "## 2. Volume Evolution — Flow vs dhdt vs Zekollari et al. (2019)"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "compile_opt idl2",
        "",
        "; --- Read Zekollari 2019 RCP8.5 volume for Aletsch (row ID = 1450) ---",
        "zek_file = zek_dir + 'ZekollariHussFarinotti_TC2019_volume_rcp85.csv'",
        "n_lines = file_lines(zek_file)",
        "all_lines = strarr(n_lines)",
        "openr, lun, zek_file, /get_lun",
        "readf, lun, all_lines",
        "free_lun, lun",
        "",
        "year_tokens = strsplit(all_lines[1], ',', /extract)",
        "zek_years = long(year_tokens[1:*])",
        "zek_vol_aletsch = !null",
        "for i = 2, n_lines - 1 do begin",
        "  tokens = strsplit(all_lines[i], ',', /extract)",
        "  if long(tokens[0]) eq 1450 then begin",
        "    zek_vol_aletsch = double(tokens[1:*])",
        "    break",
        "  endif",
        "endfor",
        "",
        "; --- Plot ---",
        "p1 = plot(fl.years, fl.volume, 'b-2', $",
        "  title='Aletsch (01450) — Volume Evolution', $",
        "  xtitle='Year', ytitle='Volume (km!U3!N)', $",
        "  xrange=[2000, 2101], font_size=11, $",
        "  name='GloGEMflow SIA (this study)')",
        "",
        "p2 = plot(dhdt.years, dhdt.volume, color='forest green', thick=2, /overplot, $",
        "  name='GloGEM dhdt')",
        "",
        "if n_elements(zek_vol_aletsch) gt 0 then begin",
        "  p3 = plot(zek_years, zek_vol_aletsch, 'r--2', /overplot, $",
        "    name='Zekollari et al. (2019), RCP8.5')",
        "  l = legend(target=[p1, p2, p3], position=[0.88, 0.83], font_size=9)",
        "endif else begin",
        "  l = legend(target=[p1, p2], position=[0.88, 0.83], font_size=9)",
        "  print, 'WARNING: Aletsch not found in Zekollari CSV'",
        "endelse",
        "",
        "print, 'Volume 2004 — flow:', fl.volume[iy2004[0]], ' dhdt:', dhdt.volume[iy2004[0]], ' km3'",
        "print, 'Volume 2100 — flow:', fl.volume[iy2100[0]], ' dhdt:', dhdt.volume[iy2100[0]], ' km3'",
        "if n_elements(zek_vol_aletsch) gt 0 then begin",
        "  iy_zek17 = where(zek_years eq 2017)",
        "  iy_zek00 = where(zek_years eq 2100)",
        "  print, 'Zekollari 2017:', zek_vol_aletsch[iy_zek17[0]], '  2100:', zek_vol_aletsch[iy_zek00[0]], ' km3'",
        "endif"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "Volume 2004 — flow:       14.235617 dhdt:       13.680760 km3",
                "Volume 2100 — flow:     0.066336200 dhdt:     0.017603243 km3",
                "Zekollari 2017:       11.892000  2100:       1.3089000 km3",
                ""
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        },
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":640,\"ysize\":512,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "markdown",
      "content": [
        "## 3. Area Evolution"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "compile_opt idl2",
        "",
        "p1 = plot(fl.years, fl.area_total, 'b-2', $",
        "  title='Aletsch (01450) — Area Evolution', $",
        "  xtitle='Year', ytitle='Area (km!U2!N)', $",
        "  xrange=[2000, 2101], font_size=11, $",
        "  name='GloGEMflow SIA')",
        "",
        "p2 = plot(dhdt.years, dhdt.area_total, color='forest green', thick=2, /overplot, $",
        "  name='GloGEM dhdt')",
        "",
        "l = legend(target=[p1, p2], position=[0.88, 0.83], font_size=9)",
        "",
        "print, 'Area 2004 — flow:', fl.area_total[iy2004[0]], ' dhdt:', dhdt.area_total[iy2004[0]], ' km2'",
        "print, 'Area 2100 — flow:', fl.area_total[iy2100[0]], ' dhdt:', dhdt.area_total[iy2100[0]], ' km2'",
        "print, '  (expected ~75-83 km2 at 2004)'"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "Area 2004 — flow:       79.993591 dhdt:       80.930368 km2",
                "Area 2100 — flow:       4.3265921 dhdt:       1.8052838 km2",
                "  (expected ~75-83 km2 at 2004)"
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        },
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":640,\"ysize\":512,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "markdown",
      "content": [
        "## 4. Glacier-wide Mass Balance"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "compile_opt idl2",
        "",
        "p1 = plot(fl.years, fl.mb, 'b-2', $",
        "  title='Aletsch — Glacier-wide Mass Balance', $",
        "  xtitle='Year', ytitle='Mass balance (m w.e. yr!U-1!N)', $",
        "  xrange=[2000, 2101], font_size=11, $",
        "  name='GloGEMflow SIA')",
        "",
        "p2 = plot(dhdt.years, dhdt.mb, color='forest green', thick=2, /overplot, $",
        "  name='GloGEM dhdt')",
        "",
        "p3 = plot([1950, 2101], [0, 0], 'k--1', /overplot)",
        "",
        "l = legend(target=[p1, p2], position=[0.88, 0.83], font_size=9)",
        "",
        "print, 'Mean MB 2004-2020 — flow:', mean(fl.mb[iy2004[0]:iy2020[0]]), $",
        "  ' dhdt:', mean(dhdt.mb[iy2004[0]:iy2020[0]]), ' m w.e./yr'"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "Mean MB 2004-2020 — flow:     -0.84381681 dhdt:      -1.0976454 m w.e./yr",
                ""
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        },
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":640,\"ysize\":512,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "markdown",
      "content": [
        "## 5. Surface and Bed Profiles Along Flowline",
        "",
        "",
        "",
        "Distance is measured from the **tongue** (x=0) to the head.",
        "",
        "Expected: tongue ~1560 m, head ~4100 m, glacier length ~23 km."
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "compile_opt idl2",
        "",
        "yrs_plot   = [2004, 2020, 2050, 2100]",
        "colors     = ['blue', 'dodger blue', 'orange red', 'firebrick']",
        "iy_arr     = [iy2004[0], iy2020[0], iy2050[0], iy2100[0]]",
        "",
        "; Start with bedrock",
        "p = plot(dist_km, fl.bed_dx, 'k-2', $",
        "  title='Aletsch — Surface & Bed Profiles', $",
        "  xtitle='Distance from tongue (km)', ytitle='Elevation (m a.s.l.)', $",
        "  yrange=[1400, 4300], font_size=11, $",
        "  name='Bedrock')",
        "",
        "; Surface profile at each year",
        "for k = 0, n_elements(yrs_plot) - 1 do begin",
        "  sur_k = reform(fl.sur[*, iy_arr[k]])",
        "  ; Only plot cells with ice (surface = bed where thick=0)",
        "  thick_k = reform(fl.thick[*, iy_arr[k]])",
        "  ii_k = where(thick_k gt 0, c_k)",
        "  if c_k gt 0 then begin",
        "    pk = plot(dist_km[ii_k], sur_k[ii_k], color=colors[k], thick=2, /overplot, $",
        "      name=strtrim(yrs_plot[k], 2))",
        "  endif",
        "endfor",
        "",
        "l = legend(font_size=9, position=[0.38, 0.82])",
        "",
        "; Sanity prints",
        "sur_init = reform(fl.sur[*, iy2004[0]])",
        "thick_init = reform(fl.thick[*, iy2004[0]])",
        "ii_ice = where(thick_init gt 0, c_ice)",
        "print, 'Tongue elevation (2004): ', min(sur_init[ii_ice]), ' m  (expected ~1560 m)'",
        "print, 'Head elevation   (2004): ', max(sur_init[ii_ice]), ' m  (expected ~3900-4100 m)'",
        "print, 'Glacier length   (2004): ', c_ice * fl.dx / 1000.0, ' km  (expected ~23 km)'"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "Tongue elevation (2004):        1626.1019 m  (expected ~1560 m)",
                "Head elevation   (2004):        3968.6375 m  (expected ~3900-4100 m)",
                "Glacier length   (2004):       19.8000 km  (expected ~23 km)",
                ""
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        },
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":640,\"ysize\":512,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "markdown",
      "content": [
        "## 6. Ice Thickness Profile",
        "",
        "",
        "",
        "Expected: max thickness ~800–900 m near the main trunk, thinning toward tongue and head."
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "compile_opt idl2",
        "",
        "yrs_plot = [2004, 2020, 2050, 2100]",
        "colors   = ['blue', 'dodger blue', 'orange red', 'firebrick']",
        "iy_arr   = [iy2004[0], iy2020[0], iy2050[0], iy2100[0]]",
        "",
        "p = plot(dist_km, reform(fl.thick[*, iy2004[0]]), color='blue', thick=2, $",
        "  title='Aletsch — Ice Thickness Profile', $",
        "  xtitle='Distance from tongue (km)', ytitle='Ice thickness (m)', $",
        "  font_size=11, name='2004')",
        "",
        "for k = 1, n_elements(yrs_plot) - 1 do begin",
        "  pk = plot(dist_km, reform(fl.thick[*, iy_arr[k]]), color=colors[k], $",
        "    thick=2, /overplot, name=strtrim(yrs_plot[k], 2))",
        "endfor",
        "",
        "l = legend(font_size=9, position=[0.88, 0.83])",
        "",
        "print, 'Max thickness 2004: ', max(reform(fl.thick[*, iy2004[0]])), ' m  (expected ~800-900 m)'",
        "print, 'Max thickness 2100: ', max(reform(fl.thick[*, iy2100[0]])), ' m'"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "Max thickness 2004:        514.19431 m  (expected ~800-900 m)",
                "Max thickness 2100:        30.468438 m"
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        },
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":640,\"ysize\":512,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "markdown",
      "content": [
        "## 7. Mass Balance Profile Along Flowline",
        "",
        "",
        "",
        "Expected: strongly negative near the tongue (~-6 m w.e./yr), positive in the accumulation zone.",
        "",
        "The zero crossing (ELA) should be around 3000–3200 m."
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "compile_opt idl2",
        "",
        "; Mass balance stored as m w.e. in fl.bal",
        "bal_2004 = reform(fl.bal[*, iy2004[0]])",
        "bal_2020 = reform(fl.bal[*, iy2020[0]])",
        "bal_2050 = reform(fl.bal[*, iy2050[0]])",
        "",
        "p = plot(dist_km, bal_2004, 'b-2', $",
        "  title='Aletsch — Mass Balance Profile', $",
        "  xtitle='Distance from tongue (km)', ytitle='Mass balance (m w.e. yr!U-1!N)', $",
        "  font_size=11, name='2004')",
        "",
        "p2 = plot(dist_km, bal_2020, color='dodger blue', thick=2, /overplot, name='2020')",
        "p3 = plot(dist_km, bal_2050, color='orange red',  thick=2, /overplot, name='2050')",
        "p4 = plot([min(dist_km), max(dist_km)], [0, 0], 'k--1', /overplot)",
        "",
        "l = legend(font_size=9, position=[0.65, 0.8])",
        "",
        "; Compute ELA as the elevation where bal crosses zero in 2004 and 2050",
        "sur_2004 = reform(fl.sur[*, iy2004[0]])",
        "sur_2050 = reform(fl.sur[*, iy2050[0]])",
        "thick_2004 = reform(fl.thick[*, iy2004[0]])",
        "thick_2050 = reform(fl.thick[*, iy2050[0]])",
        "",
        "; Find ELA: last cell (toward head) where bal transitions from neg to pos",
        "ii_ice_2004 = where(thick_2004 gt 0 and finite(bal_2004), c_i2004)",
        "ela_2004 = !values.f_nan",
        "if c_i2004 gt 1 then begin",
        "  for i = 0, c_i2004 - 2 do begin",
        "    i1 = ii_ice_2004[i]",
        "    i2 = ii_ice_2004[i+1]",
        "    if bal_2004[i1] lt 0 and bal_2004[i2] ge 0 then begin",
        "      ; Linear interpolation",
        "      frac = (-bal_2004[i1]) / (bal_2004[i2] - bal_2004[i1])",
        "      ela_2004 = sur_2004[i1] + frac * (sur_2004[i2] - sur_2004[i1])",
        "    endif",
        "  endfor",
        "endif",
        "",
        "ii_ice_2050 = where(thick_2050 gt 0 and finite(bal_2050), c_i2050)",
        "ela_2050 = !values.f_nan",
        "if c_i2050 gt 1 then begin",
        "  for i = 0, c_i2050 - 2 do begin",
        "    i1 = ii_ice_2050[i]",
        "    i2 = ii_ice_2050[i+1]",
        "    if bal_2050[i1] lt 0 and bal_2050[i2] ge 0 then begin",
        "      frac = (-bal_2050[i1]) / (bal_2050[i2] - bal_2050[i1])",
        "      ela_2050 = sur_2050[i1] + frac * (sur_2050[i2] - sur_2050[i1])",
        "    endif",
        "  endfor",
        "endif",
        "",
        "print, 'ELA 2004: ', ela_2004, ' m  (expected ~3000-3200 m)'",
        "print, 'ELA 2050: ', ela_2050, ' m  (expected higher due to warming)'"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "ELA 2004:        3020.0546 m  (expected ~3000-3200 m)",
                "ELA 2050:        3388.9233 m  (expected higher due to warming)",
                ""
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        },
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":640,\"ysize\":512,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "markdown",
      "content": [
        "## 8. ELA Evolution Through Time"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "compile_opt idl2",
        "",
        "nyears = n_elements(fl.years)",
        "ela_ts = dblarr(nyears) + !values.d_nan",
        "",
        "for iy = 0, nyears - 1 do begin",
        "  bal_yr   = reform(fl.bal[*, iy])",
        "  sur_yr   = reform(fl.sur[*, iy])",
        "  thick_yr = reform(fl.thick[*, iy])",
        "  ii_ice_yr = where(thick_yr gt 0 and finite(bal_yr), c_yr)",
        "  if c_yr lt 2 then continue",
        "  for i = 0, c_yr - 2 do begin",
        "    i1 = ii_ice_yr[i]",
        "    i2 = ii_ice_yr[i+1]",
        "    if bal_yr[i1] lt 0 and bal_yr[i2] ge 0 then begin",
        "      frac = (-bal_yr[i1]) / (bal_yr[i2] - bal_yr[i1])",
        "      ela_ts[iy] = sur_yr[i1] + frac * (sur_yr[i2] - sur_yr[i1])",
        "    endif",
        "  endfor",
        "endfor",
        "",
        "; Only plot years where ELA could be computed",
        "ii_valid = where(finite(ela_ts), c_valid)",
        "if c_valid gt 0 then begin",
        "  p = plot(fl.years[ii_valid], ela_ts[ii_valid], 'b-2', $",
        "    title='Aletsch — ELA Evolution', $",
        "    xtitle='Year', ytitle='ELA (m a.s.l.)', $",
        "    xrange=[2000, 2101], font_size=11)",
        "  print, 'ELA range: ', min(ela_ts[ii_valid]), ' to ', max(ela_ts[ii_valid]), ' m'",
        "endif else begin",
        "  print, 'WARNING: could not compute ELA for any year'",
        "endelse"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "ELA range:        2671.8861 to        3944.4901 m"
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        },
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":640,\"ysize\":512,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "markdown",
      "content": [
        "## 9. Numerical Stability Check",
        "",
        "",
        "",
        "Check for blow-ups, NaNs, and unphysical thickness values."
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "compile_opt idl2",
        "",
        "nyears = n_elements(fl.years)",
        "",
        "; Check for NaNs in thickness",
        "n_nan = 0l",
        "n_blowup = 0l",
        "for iy = 0, nyears - 1 do begin",
        "  thick_yr = reform(fl.thick[*, iy])",
        "  n_nan    = n_nan + total(~finite(thick_yr))",
        "  n_blowup = n_blowup + total(thick_yr gt 2000)",
        "endfor",
        "",
        "print, '=== Numerical stability ==='",
        "print, 'NaN cells across all years: ', n_nan",
        "print, 'Blow-up cells (>2000 m):   ', n_blowup",
        "",
        "; Volume should be monotonically decreasing under warming after ~2005",
        "ii_start = where(fl.years eq 2005)",
        "if ii_start[0] ge 0 then begin",
        "  vol_after = fl.volume[ii_start[0]:*]",
        "  dvdt = vol_after[1:*] - vol_after[0:n_elements(vol_after)-2]",
        "  n_pos_dvdt = total(dvdt gt 0.05)  ; allow small noise",
        "  print, 'Years with volume INCREASE after 2005 (>0.05 km3): ', n_pos_dvdt",
        "  if n_pos_dvdt gt 5 then print, 'WARNING: unexpected volume increases — check spin-up'",
        "endif",
        "",
        "; Plot thickness time series at a mid-glacier cell to check for spikes",
        "i_mid = fl.xnum / 2",
        "p = plot(fl.years, reform(fl.thick[i_mid, *]), 'b-1', $",
        "  title='Thickness at mid-glacier cell (i=' + strtrim(i_mid,2) + ')', $",
        "  xtitle='Year', ytitle='Thickness (m)', font_size=11)",
        "print, 'Mid-glacier thickness range: ', min(reform(fl.thick[i_mid,*])), $",
        "  ' to ', max(reform(fl.thick[i_mid,*])), ' m'"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "=== Numerical stability ===",
                "NaN cells across all years:       0.00000",
                "Blow-up cells (>2000 m):         0.00000",
                "Years with volume INCREASE after 2005 (>0.05 km3):       2.00000",
                "Mid-glacier thickness range:        0.0000000 to        422.22037 m",
                ""
              ]
            }
          ],
