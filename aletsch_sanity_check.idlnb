    {
      "type": "markdown",
      "content": [
        "## 11. SIA Flow vs dhdt — Comparative Statistics",
        "",
        "Quantifies how much the two geometry evolution approaches diverge.",
        "Key metrics: volume/area loss, timing of retreat milestones, and the",
        "divergence of the two trajectories over time."
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "compile_opt idl2",
        "",
        "; --- Find common year range ---",
        "yr_start = max([min(fl.years), min(dhdt.years)])",
        "yr_end   = min([max(fl.years), max(dhdt.years)])",
        "ii_fl   = where(fl.years   ge yr_start and fl.years   le yr_end)",
        "ii_dh   = where(dhdt.years ge yr_start and dhdt.years le yr_end)",
        "yrs_common = fl.years[ii_fl]",
        "",
        "; --- Key year indices within the common window ---",
        "iy04 = where(yrs_common eq 2004)",
        "iy20 = where(yrs_common eq 2020)",
        "iy50 = where(yrs_common eq 2050)",
        "iy00 = where(yrs_common eq 2100)",
        "",
        "fl_vol   = fl.volume[ii_fl]",
        "dh_vol   = dhdt.volume[ii_dh]",
        "fl_area  = fl.area_total[ii_fl]",
        "dh_area  = dhdt.area_total[ii_dh]",
        "",
        "; Reference volumes at start of common period",
        "v0_fl = fl_vol[iy04[0]]",
        "v0_dh = dh_vol[iy04[0]]",
        "",
        "print, '======================================================='",
        "print, '  VOLUME (km3)'",
        "print, '======================================================='",
        "print, 'Year   Flow     dhdt     Diff     Diff(%flow)'",
        "yrs_check = [2004, 2020, 2050, 2100]",
        "for k = 0, n_elements(yrs_check) - 1 do begin",
        "  iy = where(yrs_common eq yrs_check[k])",
        "  if iy[0] lt 0 then continue",
        "  diff    = fl_vol[iy[0]] - dh_vol[iy[0]]",
        "  diff_pc = diff / fl_vol[iy[0]] * 100d0",
        "  print, yrs_check[k], fl_vol[iy[0]], dh_vol[iy[0]], diff, diff_pc",
        "endfor",
        "",
        "print, ''",
        "print, '======================================================='",
        "print, '  VOLUME LOSS relative to 2004 (%)'",
        "print, '======================================================='",
        "print, 'Year   Flow(%)  dhdt(%)'",
        "for k = 1, n_elements(yrs_check) - 1 do begin",
        "  iy = where(yrs_common eq yrs_check[k])",
        "  if iy[0] lt 0 then continue",
        "  loss_fl = (v0_fl - fl_vol[iy[0]]) / v0_fl * 100d0",
        "  loss_dh = (v0_dh - dh_vol[iy[0]]) / v0_dh * 100d0",
        "  print, yrs_check[k], loss_fl, loss_dh",
        "endfor",
        "",
        "print, ''",
        "print, '======================================================='",
        "print, '  AREA (km2)'",
        "print, '======================================================='",
        "print, 'Year   Flow     dhdt     Diff'",
        "for k = 0, n_elements(yrs_check) - 1 do begin",
        "  iy = where(yrs_common eq yrs_check[k])",
        "  if iy[0] lt 0 then continue",
        "  print, yrs_check[k], fl_area[iy[0]], dh_area[iy[0]], fl_area[iy[0]] - dh_area[iy[0]]",
        "endfor",
        "",
        "print, ''",
        "print, '======================================================='",
        "print, '  RETREAT MILESTONES'",
        "print, '======================================================='",
        "",
        "; Year when each model loses 50% of its 2004 volume",
        "ii_half_fl = where(fl_vol le v0_fl * 0.5d0, c_half_fl)",
        "ii_half_dh = where(dh_vol le v0_dh * 0.5d0, c_half_dh)",
        "if c_half_fl gt 0 then $",
        "  print, 'Flow model reaches 50% volume loss: ', yrs_common[ii_half_fl[0]] $",
        "else $",
        "  print, 'Flow model does NOT reach 50% volume loss by ', yr_end",
        "if c_half_dh gt 0 then $",
        "  print, 'dhdt model reaches 50% volume loss: ', yrs_common[ii_half_dh[0]] $",
        "else $",
        "  print, 'dhdt model does NOT reach 50% volume loss by ', yr_end",
        "",
        "; Year of glacier disappearance (volume < 0.01 km3)",
        "ii_gone_fl = where(fl_vol lt 0.01d0, c_gone_fl)",
        "ii_gone_dh = where(dh_vol lt 0.01d0, c_gone_dh)",
        "if c_gone_fl gt 0 then $",
        "  print, 'Flow model glacier gone by: ', yrs_common[ii_gone_fl[0]] $",
        "else $",
        "  print, 'Flow model glacier survives beyond ', yr_end",
        "if c_gone_dh gt 0 then $",
        "  print, 'dhdt model glacier gone by: ', yrs_common[ii_gone_dh[0]] $",
        "else $",
        "  print, 'dhdt model glacier survives beyond ', yr_end",
        "",
        "print, ''",
        "print, '======================================================='",
        "print, '  TRAJECTORY DIVERGENCE'",
        "print, '======================================================='",
        "; RMSE of volume trajectories over the common period",
        "rmse_vol = sqrt(mean((fl_vol - dh_vol)^2))",
        "max_diff = max(abs(fl_vol - dh_vol), imax)",
        "print, 'RMSE(flow, dhdt) volume: ', rmse_vol, ' km3'",
        "print, 'Max divergence:          ', max_diff, ' km3  at year ', yrs_common[imax]",
        "",
        "; Plot volume divergence (flow - dhdt) over time",
        "p = plot(yrs_common, fl_vol - dh_vol, 'b-2', $",
        "  title='Volume Divergence: GloGEMflow SIA minus dhdt', $",
        "  xtitle='Year', ytitle='!7D!3V (km!U3!N)  [flow - dhdt]', $",
        "  xrange=[yr_start, yr_end], font_size=11)",
        "p2 = plot([yr_start, yr_end], [0, 0], 'k--1', /overplot)",
        "t = text(0.15, 0.20, $",
        "  'Negative = SIA loses more volume than dhdt', $",
        "  /normal, font_size=9, color='dark grey')"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "=======================================================",
                "  VOLUME (km3)",
                "=======================================================",
                "Year   Flow     dhdt     Diff     Diff(%flow)",
                "        2004       14.235617       13.680760      0.55485691       3.8976667",
                "        2020       12.800792       12.049536      0.75125678       5.8688303",
                "        2050       7.9926538       7.4158748      0.57677900       7.2163641",
                "        2100     0.066336200     0.017603243     0.048732957       73.463594",
                "",
                "=======================================================",
                "  VOLUME LOSS relative to 2004 (%)",
                "=======================================================",
                "Year   Flow(%)  dhdt(%)",
                "        2020       10.079119       11.923494",
                "        2050       43.854532       45.793401",
                "        2100       99.534012       99.871328",
                "",
                "=======================================================",
                "  AREA (km2)",
                "=======================================================",
                "Year   Flow     dhdt     Diff",
                "        2004       79.993591       80.930368     -0.93677627",
                "        2020       77.530868       77.231467      0.29940144",
                "        2050       70.505084       64.536603       5.9684814",
                "        2100       4.3265921       1.8052838       2.5213083",
                "",
                "=======================================================",
                "  RETREAT MILESTONES",
                "=======================================================",
                "Flow model reaches 50% volume loss:         2054",
                "dhdt model reaches 50% volume loss:         2053",
                "Flow model glacier survives beyond         2100",
                "dhdt model glacier survives beyond         2100",
                "",
                "=======================================================",
                "  TRAJECTORY DIVERGENCE",
                "=======================================================",
                "RMSE(flow, dhdt) volume:       0.48018430 km3",
                "Max divergence:                0.89781167 km3  at year         2033",
                ""
              ]
            }
          ],
          "metadata": {
