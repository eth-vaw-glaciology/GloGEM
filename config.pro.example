; GloGEM user configuration
; Copy this file to config.pro and uncomment/set the values you want to override.
; Settings here are applied after procedures/initialise/settings.pro, so anything set here takes precedence.
; config.pro is git-ignored and will never be accidentally committed.
;
; Setup (run once per machine):
;   cp config.pro.example config.pro
;   (then edit config.pro with your values)
;
; This file lists the most commonly adjusted settings. If you need to override a setting
; that is not listed here, simply copy the corresponding line from settings.pro into your
; config.pro and change the value. Every variable defined in settings.pro can be overridden
; this way — config.pro is always loaded last and takes precedence over settings.pro.

; -----------------------------------------------------------------------
; OUTPUT DIRECTORY  (required - different for every user / server)
; -----------------------------------------------------------------------
;dirres = '/scratch_net/yourserver/yourusername/GloGEM/output/' ; needs a "/" at the end

; -----------------------------------------------------------------------
; RGI VERSION
; -----------------------------------------------------------------------
;RGIversion = '6'                ; version of the RGI to be used

; -----------------------------------------------------------------------
; TIME RESOLUTION
; -----------------------------------------------------------------------
;time_resolution = 'daily'       ; 'daily' or 'monthly'

; -----------------------------------------------------------------------
; RUN SELECTION
; -----------------------------------------------------------------------
;region_id_loop = [14, 14]       ; region IDs to run (see region lookup at end of file)
;single_glacier = '01450'        ; single glacier RGI ID ('' to disable)
;catchment_selection = ''        ; catchment name ('' for single glacier or full region)
;size_range = [0.002, 100000]    ; [km2] glacier size filter

; -----------------------------------------------------------------------
; RUN MODE
; -----------------------------------------------------------------------
;tran = [1940, 2100]             ; modelling time period
;find_startyear = 'y'            ; 'y' to auto-detect first future year from inventory date
;calibrate = 'n'                 ; 'y' to calibrate, 'n' to run with given parameters

; -----------------------------------------------------------------------
; CALIBRATION SETTINGS
; -----------------------------------------------------------------------
;calperiod_ID = 9                ; ID specifying calibration period (see settings.pro for list)
;caliphase_loop = 3              ; 1: default (no loop); 2: phases 1-2; 3: phases 1-3
;calibration_phase = '1'        ; starting calibration phase: 1: c_prec, 2: DDF_snow, 3: T-bias

; -----------------------------------------------------------------------
; CLIMATE DATA — MODEL INTERCOMPARISON PROJECT
; -----------------------------------------------------------------------
; Set MIP to choose the model intercomparison project, then use the *_idx
; variables to select which GCMs, SSPs, and experiments to run.
; Index syntax (1-based): [0] = full batch; [1,2] = first two; indgen(n)+k
; selects n consecutive entries starting at k (e.g. indgen(5)+1 for 1-5).
; GCM and SSP/RCP codes: see GCM/SSP lookup at end of file.
; -----------------------------------------------------------------------
;MIP = 'CMIP6'                   ; 'CMIP6' (default), 'CMIP5', or 'GMIP4'
;long_GCM = ''                   ; '' for runs to 2100, 'long_' for runs to 2300
;GCM_model_idx    = [0]          ; model indices (1-based); [0] = all; e.g. [1,2,5]
;GCM_rcp_idx      = [0]          ; SSP/RCP indices;          [0] = all; e.g. [4]
;GCM_model_range  = [1, 4]       ; consecutive range shorthand: [first, last]; overrides GCM_model_idx
;GCM_rcp_range    = [0, 0]       ; consecutive range shorthand for SSPs
;first_GCM = 0                   ; starting GCM for batch (0-based, minus 1)

; Manual override — only needed to bypass the lookup table entirely
;GCM_model = ['BCC-CSM2-MR', 'CESM2']
;GCM_rcp = ['ssp126', 'ssp585']

; -----------------------------------------------------------------------
; REANALYSIS / BIAS CORRECTION
; -----------------------------------------------------------------------
;reanalysis = 'era5'             ; 'era5', 'era5land', 'chelsaw5e5', 'gswp3w5e5', 'ch2018', 'ERA5'
;bias_correction = 'y'           ; 'y' to apply GCM bias correction
;bias_correction_method = 1      ; 1: delta method; 2: quantile mapping (daily T only)

; -----------------------------------------------------------------------
; MELT MODEL
; -----------------------------------------------------------------------
;meltmodel = '1'                 ; '1': degree-day model, '3': simple energy-balance (Oerlemans)

; -----------------------------------------------------------------------
; MODEL PHYSICS (enable / disable modules)
; -----------------------------------------------------------------------
;debris_supraglacial = 'n'       ; 'y' to activate supraglacial debris model
;refreezing_full = 'n'           ; 'y' to activate full refreezing model (slow)
;refreezing_parametrised = 'y'   ; 'y' to activate parametrised refreezing
;firnice_temperature = 'n'       ; 'y' to activate englacial ice/firn temperature model
;frontal_ablation = 'y'          ; 'y' to activate frontal ablation / calving model

; -----------------------------------------------------------------------
; GEOMETRY EVOLUTION MODEL
; Two mutually exclusive options:
;   option 1 — dhdt parameterisation (Huss et al., 2010): glacier_retreat='y', use_flow_model='n'
;   option 2 — coupled flowline model GloGEMflow (Zekollari et al., 2019): use_flow_model='y'
; -----------------------------------------------------------------------
;glacier_retreat = 'y'           ; 'y' to activate dhdt geometry change (option 1)
;use_flow_model = 'n'            ; 'y' to activate GloGEMflow instead of dhdt (option 2)

; -----------------------------------------------------------------------
; OUTPUT OPTIONS
; -----------------------------------------------------------------------
;version_past = ''               ; version tag appended to PAST output folder name
;full_output = 'n'               ; 'y' for extended set of output files (see settings.pro)
;write_file = 'y'                ; 'y' to write result files to disk
;write_mb_elevationbands = 'n'   ; 'y' to write seasonal MB per elevation band
;eval_mbelevsensitivity = 'n'    ; 'y' to evaluate MB sensitivity per elevation band
;count_mbelevsens_v0 = 5         ; number of elevation steps for MB sensitivity evaluation
;write_hypsometry_files = 'n'    ; 'y' to write annual hypsometry for all glaciers
;write_geometry_output = 'n'    ; 'y' to save per-glacier geometry and flowline grid history (.sav)

; -----------------------------------------------------------------------
; LOOKUP TABLES
; -----------------------------------------------------------------------
;
; GCM / SSP codes  (GCM_model_idx, GCM_rcp_idx):
;
;   CMIP6 (default):
;     GCM_model (14):
;       1: BCC-CSM2-MR    2: CAMS-CSM1-0    3: CESM2          4: CESM2-WACCM
;       5: EC-Earth3      6: EC-Earth3-Veg  7: FGOALS-f3-L    8: GFDL-ESM4
;       9: INM-CM4-8     10: INM-CM5-0     11: MPI-ESM1-2-HR 12: MRI-ESM2-0
;      13: NorESM2-MM    14: CanESM5
;     GCM_rcp (6):  1:ssp126  2:ssp245  3:ssp370  4:ssp585  5:ssp119  6:ssp534-over
;
;   CMIP5:
;     GCM_model (14):
;       1: BCC-CSM1-1    2: CanESM2        3: CCSM4          4: CNRM-CM5
;       5: CSIRO-Mk3-6-0 6: GFDL-CM3       7: GISS-E2-R      8: HadGEM2-ES
;       9: INMCM4       10: IPSL-CM5A-LR  11: MIROC-ESM     12: MPI-ESM-LR
;      13: MRI-CGCM3    14: NorESM1-M
;     GCM_rcp (3):  1:rcp26  2:rcp45  3:rcp85
;
;   GMIP4 (Glacier MIP 4 — fixed protocol; not all model/SSP combos available):
;     GCM_model (8):
;       1: ACCESS-ESM1-5  2: BCC-CSM2-MR   3: CESM2-WACCM   4: IPSL-CM6A-LR
;       5: MRI-ESM2-0     6: MPI-ESM1-2-HR 7: MIROC6         8: NorESM2-MM
;     GCM_rcp (4):  1:ssp126  2:ssp370  3:ssp585  4:ssp534-over
;
; Regions  (region_id_loop):
;   region (31):
;     1: Alaska              2: WesternCanada      3: ArcticCanadaN      4: ArcticCanadaS
;     5: Greenland           6: Iceland            7: Svalbard           8: Scandinavia
;     9: RussianArctic      10: NorthAsia/Altay   11: NorthAsia/Chukotka 12: NorthAsia/East
;    13: NorthAsia/North    14: CentralEurope     15: Caucasus          16: CentralAsia
;    17: SouthAsiaWest      18: SouthAsiaEast     19: LowLat/Andes      20: LowLat/Africa
;    21: LowLat/Mexico      22: LowLat/Newguinea  23: SouthernAndes     24: NewZealand
;    25: Antarctic/Atlantic 26: Antarctic/Indian  27: Antarctic/Pacific 28: Antarctic/MaudWilkes
;    29: Antarctic/Victoria 30: Antarctic/Peninsula 31: Antarctic/MarieByrd
; -----------------------------------------------------------------------

; -----------------------------------------------------------------------
; NETCDF OUTPUT  (GlacierMIP4-compliant)
; -----------------------------------------------------------------------
;write_netcdf = 'n'              ; 'y' to write NetCDF output following GlacierMIP4 conventions
;                                ;   - hindcast runs  -> PAST/PAST_netcdf/
;                                ;   - projection runs -> files/files_netcdf/full/
;netcdf_split = 'n'              ; 'y' to additionally split projection runs into:
;                                ;   past portion  -> PAST/PAST_netcdf/   (reanalysis naming)
;                                ;   future portion -> files/files_netcdf/split/ (GCM naming)
;netcdf_split_year = 2025        ; first year of the projection period (split boundary)
