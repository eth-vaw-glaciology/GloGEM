                "       1219.6099       1179.9655       1140.3210       1100.6766       1061.0321",
                "       1021.3877       981.74325       942.09881       902.45437       862.80992",
                "       823.16548       783.52103       743.87659       704.23214       664.58770"
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "avg_slope"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
