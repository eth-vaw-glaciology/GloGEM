      ]
    },
    {
      "type": "code",
      "content": [
        "highest_elev_pre_frontal = prefrontal_elev[0]",
        "lowest_elev_pre_frontal = prefrontal_elev[n_elements(prefrontal_elev) - 1]",
        "highest_x_pre_frontal = x_concat[0]",
        "lowest_x_pre_frontal = x_concat[n_elements(x_concat) - 1]",
        "slope = (highest_elev_pre_frontal - lowest_elev_pre_frontal) / (lowest_x_pre_frontal - highest_x_pre_frontal)"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "markdown",
      "content": [
        "Calculation of 0 point needs to be finished!"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; ; Add point where bedrock elevation would be zero",
        "; zero_elev_x = lowest_x_pre_frontal + (0 - lowest_elev_pre_frontal) / slope",
        "; prefrontal_elev = [prefrontal_elev, 0.0]",
        "; x_concat = [x_concat, zero_elev_x]",
        ""
      ],
      "metadata": {},
