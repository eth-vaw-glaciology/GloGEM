    {
      "type": "code",
      "content": [
        "; merge bedrock elevation with prefrontal region",
        "bed_x = [bed_x, prefrontal_elev]",
        "",
        "; extend all other arrays to match the size of the bedrock elevation array (& set to 0)",
        ""
