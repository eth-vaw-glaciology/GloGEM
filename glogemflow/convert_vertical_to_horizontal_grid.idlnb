    {
      "type": "markdown",
      "content": [
        "Calculation of 0 point needs to be finished!"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; ; Add point where bedrock elevation would be zero",
        "zero_elev_x = lowest_elev_pre_frontal / slope + lowest_x_pre_frontal",
        "prefrontal_elev = reverse(prefrontal_elev) ; reverse the order of the array to match the order of lowest to highest elevation",
        "prefrontal_elev = [prefrontal_elev, 0.0]",
        "x_concat = [x_concat, zero_elev_x]",
        ""
      ],
      "metadata": {},
      "outputs": []
    },
