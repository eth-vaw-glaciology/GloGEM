      ]
    },
    {
      "type": "code",
      "content": [
        "x_concat[0]"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "       20200.000",
                ""
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "highest_elev_pre_frontal = prefrontal_elev[-1]",
        "lowest_elev_pre_frontal = prefrontal_elev[0]",
        "highest_x_pre_frontal = x_concat[0]",
        "lowest_x_pre_frontal = x_concat[- 1]",
        "slope = (highest_elev_pre_frontal - lowest_elev_pre_frontal) / (lowest_x_pre_frontal - highest_x_pre_frontal)"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "slope"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
