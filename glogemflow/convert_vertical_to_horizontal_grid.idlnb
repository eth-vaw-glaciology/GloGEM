                "       996.85436532507754       1031.2543653250775       1065.6543653250774",
                "       1100.0543653250775       1134.4543653250776       1168.8543653250777",
                "       1203.2543653250775       1237.6543653250774       1272.0543653250775",
                "       1306.4543653250776       1340.8543653250774       1375.2543653250775",
