{
  "version": "2.0.0",
  "cells": [
    {
      "type": "markdown",
      "content": [
        "# GloGEM test: Aletsch & Morteratsch — output visualisation",
        "",
        "This notebook reads and visualises GloGEM outputs from the four test runs.",
        "Run the model first (from the GloGEM root in IDL):",
        "",
        "```",
        "cp test/config_aletsch_daily_calib.pro     config.pro  &&  .r glogem",
        "cp test/config_aletsch_daily_hindcast.pro  config.pro  &&  .r glogem",
        "cp test/config_aletsch_monthly_calib.pro   config.pro  &&  .r glogem",
        "cp test/config_aletsch_monthly_hindcast.pro config.pro  &&  .r glogem",
        "```",
        "",
        "Then open this notebook and run all cells."
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "markdown",
      "content": [
        "## 1. Setup",
        "",
        "Paths are detected automatically from the notebook location —",
        "no manual editing required."
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; Locate the notebook and derive all paths",
        "TEST_DIR = file_dirname(routine_filepath())",
        "OUT_DIR  = TEST_DIR + '/outputs'",
        "CC       = '_Aletsch_Morteratsch'   ; catchment suffix in output filenames",
        "PLOT_DIR = TEST_DIR + '/example_plots'",
        "if ~file_test(PLOT_DIR, /DIRECTORY) then file_mkdir, PLOT_DIR",
        "",
        "ok = 1",
        "foreach f, [ $",
        "  OUT_DIR + '/daily/CentralEurope/PAST/PAST_original/centraleurope_Annual_Balance_sfc_r1' + CC + '.dat', $",
        "  OUT_DIR + '/monthly/CentralEurope/PAST/PAST_original/centraleurope_Annual_Balance_sfc_r1' + CC + '.dat' $",
        "] do begin",
        "  if ~file_test(f) then begin & print, 'MISSING: ' + f & ok = 0 & endif",
        "endforeach",
        "if ok then print, 'Output files found - ready to visualise.' $",
        "else print, 'Run the four model passes first (see notebook header).'"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "Output files found - ready to visualise."
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "markdown",
      "content": [
        "## 2. Calibration results",
        "",
        "Per-glacier calibrated parameters from both the daily and monthly runs."
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; ---- Daily calibration ----",
        "cal_file_d = OUT_DIR + '/daily/CentralEurope/calibration/' + $",
        "             'calibrate_m1_cID9_centraleurope_final_era5' + CC + '.dat'",
        "if ~file_test(cal_file_d) then begin & print, 'Not found: ' + cal_file_d & stop & endif",
        "n = file_lines(cal_file_d) - 1",
        "hdr = strarr(1) & dat = strarr(n)",
        "openr, 1, cal_file_d & readf, 1, hdr & readf, 1, dat & close, 1",
        "print, 'Daily calibration:' & print, hdr[0]",
        "for i = 0, n-1 do print, dat[i]",
        "cal_id    = strarr(n) & cal_ba    = dblarr(n) & cal_ddfs = dblarr(n)",
        "cal_ddfi  = dblarr(n) & cal_cprec = dblarr(n) & cal_toff = dblarr(n)",
        "cal_ela   = dblarr(n) & cal_aar   = dblarr(n)",
        "for i = 0, n-1 do begin",
        "  p = strsplit(dat[i], ' ', /extract)",
        "  cal_id[i]=p[0] & cal_ba[i]=double(p[1]) & cal_ela[i]=double(p[4])",
        "  cal_aar[i]=double(p[5]) & cal_ddfs[i]=double(p[8]) & cal_ddfi[i]=double(p[9])",
        "  cal_cprec[i]=double(p[10]) & cal_toff[i]=double(p[11])",
        "endfor",
        "idx_al_c = (where(cal_id eq '02596'))[0]",
        "idx_mo_c = (where(cal_id eq '02216'))[0]",
        "",
        "; ---- Monthly calibration ----",
        "cal_file_m = OUT_DIR + '/monthly/CentralEurope/calibration/' + $",
        "             'calibrate_m1_cID9_centraleurope_final_era5' + CC + '.dat'",
        "if ~file_test(cal_file_m) then begin & print, 'Not found: ' + cal_file_m & stop & endif",
        "n = file_lines(cal_file_m) - 1",
        "hdr = strarr(1) & dat = strarr(n)",
        "openr, 1, cal_file_m & readf, 1, hdr & readf, 1, dat & close, 1",
        "print, '' & print, 'Monthly calibration:' & print, hdr[0]",
        "for i = 0, n-1 do print, dat[i]",
        "cal_m_id = strarr(n) & cal_m_ba = dblarr(n)",
        "cal_m_ddfs = dblarr(n) & cal_m_ddfi = dblarr(n) & cal_m_cprec = dblarr(n)",
        "for i = 0, n-1 do begin",
        "  p = strsplit(dat[i], ' ', /extract)",
        "  cal_m_id[i]=p[0] & cal_m_ba[i]=double(p[1])",
        "  cal_m_ddfs[i]=double(p[8]) & cal_m_ddfi[i]=double(p[9]) & cal_m_cprec[i]=double(p[10])",
        "endfor",
        "idx_al_cm = (where(cal_m_id eq '02596'))[0]",
        "idx_mo_cm = (where(cal_m_id eq '02216'))[0]"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "Daily calibration:",
                "ID        Ba         Bw     Area     ELA   AAR    dBdz   Bt    DDFsnow  DDFice   Cprec   T_off  Flag",
                "02596   -1.167    0.871     81.820  3101  53.8    0.892  -13.601  3.606  7.212    0.800   0.00  1",
                "02216   -0.968    0.944     15.790  3062  47.9    0.774   -8.159  3.000  6.000    1.342   0.00  1",
                "",
                "Monthly calibration:",
                "ID        Ba         Bw     Area     ELA   AAR    dBdz   Bt    DDFsnow  DDFice   Cprec   T_off  Flag",
                "02596   -1.194    0.280     81.820  3192  47.1    0.789  -12.762  3.342  6.684    0.800   0.00  1",
                "02216   -0.991    0.444     15.790  3142  42.4    0.700   -7.951  3.000  6.000    1.522   0.00  1",
                ""
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "markdown",
      "content": [
        "## 3. Read hindcast time series"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; ---- Daily hindcast ----",
        "mb_d_file = OUT_DIR + '/daily/CentralEurope/PAST/PAST_original/centraleurope_Annual_Balance_sfc_r1' + CC + '.dat'",
        "n_gl = file_lines(mb_d_file) - 1",
        "hdr = strarr(1) & dat = strarr(n_gl)",
        "openr, 1, mb_d_file & readf, 1, hdr & readf, 1, dat & close, 1",
        "parts = strsplit(hdr[0], ' ', /extract) & yrs_d = double(parts[1:*])",
        "gl_ids_d = strarr(n_gl) & mb_d = dblarr(n_gl, n_elements(yrs_d))",
        "for i = 0, n_gl-1 do begin",
        "  p = strsplit(dat[i], ' ', /extract) & gl_ids_d[i]=p[0] & mb_d[i,*]=double(p[1:*])",
        "endfor",
        "idx_al = (where(gl_ids_d eq '02596'))[0]",
        "idx_mo = (where(gl_ids_d eq '02216'))[0]",
        "",
        "; ---- Monthly hindcast ----",
        "mb_m_file = OUT_DIR + '/monthly/CentralEurope/PAST/PAST_original/centraleurope_Annual_Balance_sfc_r1' + CC + '.dat'",
        "n_gl = file_lines(mb_m_file) - 1",
        "hdr = strarr(1) & dat = strarr(n_gl)",
        "openr, 1, mb_m_file & readf, 1, hdr & readf, 1, dat & close, 1",
        "parts = strsplit(hdr[0], ' ', /extract) & yrs_m = double(parts[1:*])",
        "gl_ids_m = strarr(n_gl) & mb_m = dblarr(n_gl, n_elements(yrs_m))",
        "for i = 0, n_gl-1 do begin",
        "  p = strsplit(dat[i], ' ', /extract) & gl_ids_m[i]=p[0] & mb_m[i,*]=double(p[1:*])",
        "endfor",
        "idx_al_m = (where(gl_ids_m eq '02596'))[0]",
        "idx_mo_m = (where(gl_ids_m eq '02216'))[0]",
        "",
        "; ---- ELA and AAR (daily) ----",
        "ela_file = OUT_DIR + '/daily/CentralEurope/PAST/PAST_original/centraleurope_ELA_r1' + CC + '.dat'",
        "aar_file = OUT_DIR + '/daily/CentralEurope/PAST/PAST_original/centraleurope_AAR_r1' + CC + '.dat'",
        "n_gl = file_lines(ela_file) - 1",
        "hdr = strarr(1) & dat = strarr(n_gl)",
        "openr, 1, ela_file & readf, 1, hdr & readf, 1, dat & close, 1",
        "ela_d = dblarr(n_gl, n_elements(yrs_d))",
        "for i = 0, n_gl-1 do begin & p = strsplit(dat[i],' ',/extract) & ela_d[i,*]=double(p[1:*]) & endfor",
        "hdr = strarr(1) & dat = strarr(n_gl)",
        "openr, 1, aar_file & readf, 1, hdr & readf, 1, dat & close, 1",
        "aar_d = dblarr(n_gl, n_elements(yrs_d))",
        "for i = 0, n_gl-1 do begin & p = strsplit(dat[i],' ',/extract) & aar_d[i,*]=double(p[1:*]) & endfor",
        "",
        "print, 'Data loaded.'",
        "print, '  Daily   mean Ba - Aletsch: ' + string(mean(mb_d[idx_al,*]),fo='(f6.3)') + $",
        "       '   Morteratsch: ' + string(mean(mb_d[idx_mo,*]),fo='(f6.3)') + ' m w.e./yr'",
        "print, '  Monthly mean Ba - Aletsch: ' + string(mean(mb_m[idx_al_m,*]),fo='(f6.3)') + $",
        "       '   Morteratsch: ' + string(mean(mb_m[idx_mo_m,*]),fo='(f6.3)') + ' m w.e./yr'"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "Data loaded.",
                "  Daily   mean Ba - Aletsch: -0.983   Morteratsch: -0.775 m w.e./yr",
                "  Monthly mean Ba - Aletsch: -0.985   Morteratsch: -0.771 m w.e./yr"
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "markdown",
      "content": [
        "## 4. Plots"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; ---- Plot 1: Daily annual mass balance ----",
        "w1 = WINDOW(DIMENSIONS=[820,420], TITLE='Daily model: Annual mass balance 1991-2020')",
        "p_al = PLOT(yrs_d, mb_d[idx_al,*], '-2', COLOR='#4682B4', FONT_SIZE=11, FONT_NAME='Nimbus Sans', $",
        "            XTITLE='Year', YTITLE='Mass balance (m w.e.)', NAME='Aletsch (daily)', YRANGE=[-5,3], $",
        "            POSITION=[0.11,0.18,0.96,0.88], /CURRENT)",
        "(p_al.axes)[0].text_orientation = 45",
        "p_mo = PLOT(yrs_d, mb_d[idx_mo,*], '-2', COLOR='#D25A1E', NAME='Morteratsch (daily)', /OVERPLOT)",
        "r_al = PLOT([1991,2020], [-1.216,-1.216], ':', COLOR='#4682B4', THICK=1.5, NAME='Aletsch (Hugonnet et al. 2021)', /OVERPLOT)",
        "r_mo = PLOT([1991,2020], [-1.022,-1.022], ':', COLOR='#D25A1E', THICK=1.5, NAME='Morteratsch (Hugonnet et al. 2021)', /OVERPLOT)",
        "leg1 = LEGEND(TARGET=[p_al,p_mo,r_al,r_mo], POSITION=[0.49,0.49], /NORMAL, FONT_SIZE=9, FONT_NAME='Nimbus Sans')",
        "w1.save, PLOT_DIR + '/plot1_annual_mb.png', RESOLUTION=150"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":820,\"ysize\":420,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        },
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":640,\"ysize\":480,\"data\":\"iVBORw0KGgoAAAANSUhEUgAAAAIAAAACCAIAAAD91JpzAAAAA3NCSVQICAjb4U/gAAAAC0lEQVQImWNgQAYAAA4AAbGa6gYAAAAASUVORK5CYII=\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "; ---- Plot 2: ELA and AAR ----",
        "w2 = WINDOW(DIMENSIONS=[960,400], TITLE='Daily model: ELA and AAR - Aletschgletscher')",
        "p_ela = PLOT(yrs_d, ela_d[idx_al,*], 'k-2', TITLE='Equilibrium Line Altitude', FONT_SIZE=11, FONT_NAME='Nimbus Sans', $",
        "             XTITLE='Year', YTITLE='ELA (m a.s.l.)', POSITION=[0.09,0.20,0.46,0.82], /CURRENT)",
        "(p_ela.axes)[0].text_orientation = 45",
        "p_aar = PLOT(yrs_d, aar_d[idx_al,*], 'k--2', TITLE='Accumulation Area Ratio', FONT_SIZE=11, FONT_NAME='Nimbus Sans', $",
        "             XTITLE='Year', YTITLE='AAR (%)', POSITION=[0.59,0.20,0.96,0.82], /CURRENT)",
        "(p_aar.axes)[0].text_orientation = 45",
        "w2.save, PLOT_DIR + '/plot2_ela_aar.png', RESOLUTION=150"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":960,\"ysize\":400,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "; ---- Plot 3: Daily vs monthly comparison ----",
        "w3 = WINDOW(DIMENSIONS=[1020,430], TITLE='Annual mass balance: daily vs monthly (1991-2020)')",
        "p1 = PLOT(yrs_d, mb_d[idx_al,*], '-2', COLOR='#4682B4', TITLE='Aletschgletscher', FONT_SIZE=11, FONT_NAME='Nimbus Sans', $",
        "          XTITLE='Year', YTITLE='MB (m w.e.)', NAME='Daily', YRANGE=[-5,3], $",
        "          POSITION=[0.08,0.19,0.48,0.82], /CURRENT)",
        "(p1.axes)[0].text_orientation = 45",
        "p2 = PLOT(yrs_m, mb_m[idx_al_m,*], '--2', COLOR='#4682B4', NAME='Monthly', /OVERPLOT)",
        "r1 = PLOT([1991,2020], [-1.216,-1.216], 'k:', NAME='Geodetic (Hugonnet et al. 2021)', /OVERPLOT)",
        "leg3 = LEGEND(TARGET=[p1,p2,r1], POSITION=[0.36,0.43], /NORMAL, FONT_SIZE=9, FONT_NAME='Nimbus Sans')",
        "p3 = PLOT(yrs_d, mb_d[idx_mo,*], '-2', COLOR='#D25A1E', TITLE='Morteratschgletscher', FONT_SIZE=11, FONT_NAME='Nimbus Sans', $",
        "          XTITLE='Year', YTITLE='MB (m w.e.)', NAME='Daily', YRANGE=[-5,3], $",
        "          POSITION=[0.57,0.19,0.97,0.82], /CURRENT)",
        "(p3.axes)[0].text_orientation = 45",
        "p4 = PLOT(yrs_m, mb_m[idx_mo_m,*], '--2', COLOR='#D25A1E', NAME='Monthly', /OVERPLOT)",
        "r2 = PLOT([1991,2020], [-1.022,-1.022], 'k:', NAME='Geodetic (Hugonnet et al. 2021)', /OVERPLOT)",
        "leg4 = LEGEND(TARGET=[p3,p4,r2], POSITION=[0.85,0.43], /NORMAL, FONT_SIZE=9, FONT_NAME='Nimbus Sans')",
        "w3.save, PLOT_DIR + '/plot3_daily_vs_monthly.png', RESOLUTION=150"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":1020,\"ysize\":430,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "; ---- Plot 4: Calibrated parameters ----",
        "; Al-d=Aletsch daily, Al-m=Aletsch monthly, Mo-d=Morteratsch daily, Mo-m=Morteratsch monthly",
        "bar_labels = ['Al-d','Al-m','Mo-d','Mo-m']",
        "x     = indgen(4) + 1",
        "ddfs  = [cal_ddfs[idx_al_c], cal_m_ddfs[idx_al_cm], cal_ddfs[idx_mo_c], cal_m_ddfs[idx_mo_cm]]",
        "ddfi  = [cal_ddfi[idx_al_c], cal_m_ddfi[idx_al_cm], cal_ddfi[idx_mo_c], cal_m_ddfi[idx_mo_cm]]",
        "cprec = [cal_cprec[idx_al_c],cal_m_cprec[idx_al_cm],cal_cprec[idx_mo_c],cal_m_cprec[idx_mo_cm]]",
        "; Colors: Aletsch=blue, Morteratsch=orange",
        "cl = ['#4682B4','#4682B4','#D25A1E','#D25A1E']",
        "w4 = WINDOW(DIMENSIONS=[1020,440], $",
        "            TITLE='Calibrated parameters  (Al=Aletsch, Mo=Morteratsch, d=daily, m=monthly)')",
        "; DDFsnow — one BARPLOT call per bar so each gets a scalar FILL_COLOR",
        "b1   = BARPLOT([1],[ddfs[0]], FILL_COLOR=cl[0], NAME='Aletsch daily', $",
        "               XRANGE=[0.3,4.7], YRANGE=[0,max(ddfs)*1.2], $",
        "               TITLE='DDFsnow (mm/d/°C)', FONT_SIZE=10, FONT_NAME='Nimbus Sans', YTITLE='mm/d/°C', $",
        "               XTICKNAME=bar_labels, XTICKV=x, XTICKLEN=0, POSITION=[0.07,0.22,0.31,0.84], /CURRENT)",
        "b1b  = BARPLOT([2],[ddfs[1]], FILL_COLOR=cl[1], NAME='Aletsch monthly',    /OVERPLOT)",
        "b1c  = BARPLOT([3],[ddfs[2]], FILL_COLOR=cl[2], NAME='Morteratsch daily',  /OVERPLOT)",
        "b1d  = BARPLOT([4],[ddfs[3]], FILL_COLOR=cl[3], NAME='Morteratsch monthly',/OVERPLOT)",
        "; DDFice",
        "b2   = BARPLOT([1],[ddfi[0]], FILL_COLOR=cl[0], XRANGE=[0.3,4.7], YRANGE=[0,max(ddfi)*1.2], $",
        "               TITLE='DDFice (mm/d/°C)', FONT_SIZE=10, FONT_NAME='Nimbus Sans', YTITLE='mm/d/°C', $",
        "               XTICKNAME=bar_labels, XTICKV=x, XTICKLEN=0, POSITION=[0.40,0.22,0.64,0.84], /CURRENT)",
        "b2b  = BARPLOT([2],[ddfi[1]], FILL_COLOR=cl[1], /OVERPLOT)",
        "b2c  = BARPLOT([3],[ddfi[2]], FILL_COLOR=cl[2], /OVERPLOT)",
        "b2d  = BARPLOT([4],[ddfi[3]], FILL_COLOR=cl[3], /OVERPLOT)",
        "; c_prec",
        "b3   = BARPLOT([1],[cprec[0]], FILL_COLOR=cl[0], XRANGE=[0.3,4.7], YRANGE=[0,max(cprec)*1.2], $",
        "               TITLE='c_prec (-)', FONT_SIZE=10, FONT_NAME='Nimbus Sans', YTITLE='-', $",
        "               XTICKNAME=bar_labels, XTICKV=x, XTICKLEN=0, POSITION=[0.73,0.22,0.97,0.84], /CURRENT)",
        "b3b  = BARPLOT([2],[cprec[1]], FILL_COLOR=cl[1], /OVERPLOT)",
        "b3c  = BARPLOT([3],[cprec[2]], FILL_COLOR=cl[2], /OVERPLOT)",
        "b3d  = BARPLOT([4],[cprec[3]], FILL_COLOR=cl[3], /OVERPLOT)",
        "; Legend — 2 columns, centred below the plots",
        "t_al  = TEXT(0.5, 0.14, 'Aletsch',     /NORMAL, ALIGNMENT=0.5, COLOR=[70,130,180],  FONT_SIZE=10, FONT_NAME='Nimbus Sans', FONT_STYLE=1, TARGET=w4)",
        "t_mo  = TEXT(0.6, 0.14, 'Morteratsch', /NORMAL, ALIGNMENT=0.5, COLOR=[210,90,30],   FONT_SIZE=10, FONT_NAME='Nimbus Sans', FONT_STYLE=1, TARGET=w4)",
        "w4.save, PLOT_DIR + '/plot4_calibrated_params.png', RESOLUTION=150"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":1020,\"ysize\":440,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "markdown",
      "content": [
        "## 5. Sanity checks",
        "",
        "Calibrated Ba within +/-0.3 m w.e./yr of the geodetic target and DDFs within",
        "plausible physical bounds indicates the model is working correctly."
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "print, '' & print, '====== Sanity checks ======'",
        "n_pass = 0  &  n_total = 0",
        "",
        "chk_labels = ['Aletsch   daily  Ba','Morteratsch daily  Ba', $",
        "              'Aletsch   monthly Ba','Morteratsch monthly Ba']",
        "chk_vals = [cal_ba[idx_al_c],cal_ba[idx_mo_c],cal_m_ba[idx_al_cm],cal_m_ba[idx_mo_cm]]",
        "chk_lo = [-1.5,-1.4,-1.5,-1.4]  &  chk_hi = [-0.8,-0.5,-0.8,-0.5]",
        "for k = 0, n_elements(chk_labels)-1 do begin",
        "  n_total++",
        "  if chk_vals[k] ge chk_lo[k] and chk_vals[k] le chk_hi[k] then begin",
        "    print, '  PASS  '+chk_labels[k]+': '+string(chk_vals[k],fo='(f7.3)') & n_pass++",
        "  endif else $",
        "    print, '  FAIL  '+chk_labels[k]+': '+string(chk_vals[k],fo='(f7.3)')+ $",
        "           '  [expected '+string(chk_lo[k],fo='(f5.2)')+' to '+string(chk_hi[k],fo='(f5.2)')+']'",
        "endfor",
        "",
        "ddf_labels = ['Aletsch daily DDFsnow','Aletsch daily DDFice']",
        "ddf_vals = [cal_ddfs[idx_al_c],cal_ddfi[idx_al_c]]  &  ddf_lo=[1.5,3.0]  &  ddf_hi=[7.5,15.0]",
        "for k = 0, 1 do begin",
        "  n_total++",
        "  if ddf_vals[k] ge ddf_lo[k] and ddf_vals[k] le ddf_hi[k] then begin",
        "    print, '  PASS  '+ddf_labels[k]+': '+string(ddf_vals[k],fo='(f7.3)') & n_pass++",
        "  endif else $",
        "    print, '  FAIL  '+ddf_labels[k]+': '+string(ddf_vals[k],fo='(f7.3)')+ $",
        "           '  [expected '+string(ddf_lo[k],fo='(f5.2)')+' to '+string(ddf_hi[k],fo='(f5.2)')+']'",
        "endfor",
        "",
        "ii_d = where(yrs_d ge 2000 and yrs_d le 2020)",
        "ii_m = where(yrs_m ge 2000 and yrs_m le 2020)",
        "hind_labels = ['Aletsch   daily  mean Ba 2000-2020','Morteratsch daily  mean Ba 2000-2020', $",
        "               'Aletsch   monthly mean Ba 2000-2020','Morteratsch monthly mean Ba 2000-2020']",
        "hind_vals = [mean(mb_d[idx_al,ii_d]),mean(mb_d[idx_mo,ii_d]), $",
        "             mean(mb_m[idx_al_m,ii_m]),mean(mb_m[idx_mo_m,ii_m])]",
        "hind_lo=[-1.5,-1.4,-1.5,-1.4]  &  hind_hi=[-0.8,-0.5,-0.8,-0.5]",
        "for k = 0, n_elements(hind_labels)-1 do begin",
        "  n_total++",
        "  if hind_vals[k] ge hind_lo[k] and hind_vals[k] le hind_hi[k] then begin",
        "    print, '  PASS  '+hind_labels[k]+': '+string(hind_vals[k],fo='(f7.3)') & n_pass++",
        "  endif else $",
        "    print, '  FAIL  '+hind_labels[k]+': '+string(hind_vals[k],fo='(f7.3)')+ $",
        "           '  [expected '+string(hind_lo[k],fo='(f5.2)')+' to '+string(hind_hi[k],fo='(f5.2)')+']'",
        "endfor",
        "",
        "n_total++",
        "ela_mean = mean(ela_d[idx_al,*])",
        "if ela_mean ge 2600 and ela_mean le 3300 then begin",
        "  print, '  PASS  Aletsch daily mean ELA 1991-2020: '+string(ela_mean,fo='(f7.0)')+' m' & n_pass++",
        "endif else $",
        "  print, '  FAIL  Aletsch daily mean ELA 1991-2020: '+string(ela_mean,fo='(f7.0)')+'  [expected 2600-3300 m]'",
        "",
        "print, '' & print, string(n_pass,fo='(i0)')+' / '+string(n_total,fo='(i0)')+' checks passed'",
        "if n_pass eq n_total then print, 'All checks passed - the model is working correctly!' $",
        "else print, 'Some checks failed - inspect the output files for details.'"
      ],
