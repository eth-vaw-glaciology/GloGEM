{
  "version": "2.0.0",
  "cells": [
    {
      "type": "markdown",
      "content": [
        "### conservative_volume_vertical_grid_update",
        "This notebook is to test the back conversion from the horizontally equidistant grid to the vertically equidistant grid using artificial glacier bin data"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; ; ========== CREATE ARTIFICIAL GLACIER DATA ==========",
        "; print, '=== CREATING ARTIFICIAL GLACIER DATA ==='",
        "",
        "; ; Horizontal grid parameters",
        "; dx = 100.0  ; <-- Adjust step size here (meters)",
        "; n_dx = 251      ; <-- Adjust number of points as needed",
        "; distance_dx = findgen(n_dx) * dx",
        "; ; dx is constant spacing",
        "",
        "; ; Create realistic glacier profile",
        "; bed_dx = 1500.0 + distance_dx * 0.05  ; Gentle upward bed slope",
        "; thickness_dx = dblarr(n_dx)",
        "",
        "; ; Create realistic thickness profile (thick in middle, thin at ends)",
        "; for i = 0, n_dx-1 do begin",
        ";   ; Parabolic thickness profile",
        ";   relative_pos = float(i) / (n_dx-1)  ; 0 to 1",
        ";   if relative_pos le 0.1 then begin",
        ";     ; Thin near terminus",
        ";     thickness_dx[i] = 50.0 * relative_pos / 0.1",
        ";   endif else if relative_pos ge 0.9 then begin",
        ";     ; Thin near head",
        ";     thickness_dx[i] = 50.0 * (1.0 - relative_pos) / 0.1",
        ";   endif else begin",
        ";     ; Thick in middle (parabolic)",
        ";     mid_factor = 4.0 * (relative_pos - 0.1) * (0.9 - relative_pos) / (0.8^2)",
        ";     thickness_dx[i] = 50.0 + 200.0 * mid_factor",
        ";   endelse",
        "; endfor",
        "",
        "; ; Calculate surface elevation",
        "; surface_dx = bed_dx + thickness_dx",
        "",
        "; ; Create width profile (wider in middle)",
        "; width_base = 100.0 + 300.0 * sin(!pi * findgen(n_dx) / (n_dx-1))",
        "; lambda_dx = dblarr(n_dx) + 2.0  ; Constant shape factor",
        "; width_dx = width_base + lambda_dx * thickness_dx",
        "",
        "; print, 'Horizontal grid created:'",
        "; print, '  Points: ', n_dx",
        "; print, '  Length: ', max(distance_dx) - min(distance_dx), ' m'",
        "; print, '  Elevation range: ', min(surface_dx), ' to ', max(surface_dx), ' m'",
        "; print, '  Max thickness: ', max(thickness_dx), ' m'",
        "; print, '  Width range: ', min(width_dx), ' to ', max(width_dx), ' m'"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "=== CREATING ARTIFICIAL GLACIER DATA ===",
                "Horizontal grid created:",
                "  Points:          251",
                "  Length:       25000.0 m",
                "  Elevation range:        1500.0000 to        2750.0000 m",
                "  Max thickness:        249.99997 m",
                "  Width range:        99.999977 to        899.99994 m"
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "; ========== RESTORE GLACIER GEOMETRY DATA FROM .SAV FILE ==========",
        "; Loads x_input, sur_input, th_input, width_input, dx, etc. and renames for consistency",
        "",
        "glacier_id = '02244'  ; <-- set your glacier ID here",
        "geometry_dir = '/Users/janoschbeer/Library/Mobile Documents/com~apple~CloudDocs/PhD/projects/GloGEM/procedures/flow/test_geometries'",
        "restore, geometry_dir + '/glacier_geometry_' + glacier_id + '.sav'",
        "",
        "; Rename for code compatibility",
        "distance_dx = x_input",
        "surface_dx  = sur_input",
        "thickness_dx = th_input",
        "width_dx = width_input",
        "bed_dx = sur_input - th_input",
        "",
        "print, 'Loaded glacier geometry for ID ', glacier_id",
        "print, '  Grid points: ', n_elements(distance_dx)"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "Loaded glacier geometry for ID 02244",
                "  Grid points:          122",
                ""
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "; ========== PLOT GLACIER PROFILE ==========",
        "",
        "; x-axis: glacier length in km",
        "x = distance_dx / 1000.0  ; convert to km",
        "",
        "; Glacier surface and bed elevation",
        "surface_elev = surface_dx",
        "bed = bed_dx",
        "",
        "; Create a window for the plot",
        "w1 = window(dimensions = [800, 600], background_color='white')",
        "",
        "; Plot bed elevation",
        "bed_plot = plot(x, bed, color='brown', thick=2, $",
        "    yrange=[min(bed), max(surface_elev)], $",
        "    xrange=[min(x), max(x)], $",
        "    xtitle='Distance along glacier (km)', ytitle='Elevation (m)', $",
        "    title='Glacier profile of ' + glacier_id, $",
        "    /current)",
        "",
        "; Fill area under bed elevation with very light gray",
        "bed_x = [x, reverse(x)]",
        "bed_y = [replicate(min(bed)-100, n_elements(x)), reverse(bed)]",
        "p_bed = polygon(bed_x, bed_y, /fill_background, fill_color=[230,230,230], /data, target=w1)",
        "",
        "; Overlay glacier surface",
        "surface_plot = plot(x, surface_elev, color='blue', thick=2, /overplot)",
        "",
        "; Fill glacier area",
        "glacier_x = [x, reverse(x)]",
        "glacier_y = [bed, reverse(surface_elev)]",
        "p = polygon(glacier_x, glacier_y, /fill_background, fill_color=[180,220,255], /data, target=w1)"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":800,\"ysize\":600,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "; ========== CREATE VERTICAL GRID WITHOUT SEGMENTATION ==========",
        "; the vertical grid resolution (dz) is adjusted based on the elevation range of the glacier surface",
        "",
        "print, ''",
        "print, '=== CREATING VERTICAL GRID ==='",
        "",
        "; Smooth surface to reduce noise",
        "surface_dx_smooth = smooth(surface_dx, 5)",
        "",
        "; Set initial vertical band spacing and options",
        "dz = 10.0",
        "min_elev_span = 1000.0   ; <-- minimum elevation span in meters (option)",
        "",
        "; Find min and max surface elevation (rounded to nearest 10)",
        "surf_min = min(surface_dx_smooth)",
        "surf_max = max(surface_dx_smooth)",
        "surf_min_rounded = ceil(surf_min/10.0)*10.0",
        "surf_max_rounded = floor(surf_max/10.0)*10.0",
        "",
        "; Calculate elevation span",
        "elev_span = surf_max_rounded - surf_min_rounded",
        "",
        "; Adjust dz if elevation span is below threshold",
        "if elev_span lt min_elev_span then begin",
        "    dz = dz * (elev_span / min_elev_span)",
        "    print, '  dz reduced to ', dz, ' m due to low elevation span (', elev_span, ' m, min allowed: ', min_elev_span, ' m)'",
        "endif",
        "",
        "; Always create ascending vertical grid",
        "surface_dz = surf_min_rounded + findgen(fix((surf_max_rounded-surf_min_rounded)/dz)+1)*dz",
        "surface_dz = surface_dz[where(surface_dz le surf_max)]",
        "",
        "nb_dz = n_elements(surface_dz)"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "",
                "=== CREATING VERTICAL GRID ===",
                "  dz reduced to       2.90000 m due to low elevation span (      290.000",
                " m, min allowed:       1000.00 m)",
                ""
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "; ========== IMPROVED DISTANCE-BASED INTERPOLATION WITH MONOTONIC SEGMENTS ==========",
        ";",
        "; Assumes: surface_dx, thickness_dx, width_dx, distance_dx, dx, surface_dz, nb_dz are defined",
        "",
        "; 1. Get valid elevation bands",
        "surf_min_dx = min(surface_dx)",
        "surf_max_dx = max(surface_dx)",
        "valid_bands = where((surface_dz ge surf_min_dx) and (surface_dz le surf_max_dx), n_valid_bands)",
        "",
        "; 2. Use original horizontal grid data (no smoothing)",
        "surface_dx_used = surface_dx",
        "thickness_dx_used = thickness_dx",
        "width_dx_used = width_dx",
        "",
        "; 3. Find monotonic segments in the surface",
        "d_surface = deriv(surface_dx_used)  ; Use derivative to find monotonic segments",
        "sign_change = where(d_surface * shift(d_surface, -1) lt 0, n_change) ; Find indices where sign changes",
        "segment_edges = [0, sign_change + 1, n_elements(surface_dx_used)]  ; Create segment edges based on sign changes",
        "",
        "; 4. Prepare output arrays for the vertical grid",
        "thickness_dz = dblarr(nb_dz)",
        "width_dz = dblarr(nb_dz)",
        "",
        "; 5. Interpolate within each monotonic segment",
        "for s = 0, n_elements(segment_edges)-2 do begin",
        "  seg_start = segment_edges[s]",
        "  seg_end = segment_edges[s+1]-1",
        "  seg_surface = surface_dx_used[seg_start:seg_end]",
        "  seg_thick = thickness_dx_used[seg_start:seg_end]",
        "  seg_width = width_dx_used[seg_start:seg_end]",
        "  ; Sort segment by surface elevation",
        "  sort_idx = sort(seg_surface)",
        "  seg_surface_sorted = seg_surface[sort_idx]",
        "  seg_thick_sorted = seg_thick[sort_idx]",
        "  seg_width_sorted = seg_width[sort_idx]",
        "  ; Find valid bands for this segment",
        "  seg_valid = where((surface_dz ge min(seg_surface_sorted)) and (surface_dz le max(seg_surface_sorted)), n_seg_valid)",
        "  if n_seg_valid gt 0 then begin",
        "    thick_interp = interpol(seg_thick_sorted, seg_surface_sorted, surface_dz[seg_valid])",
        "    width_interp = interpol(seg_width_sorted, seg_surface_sorted, surface_dz[seg_valid])",
        "    for j=0, n_seg_valid-1 do begin",
        "      idx = seg_valid[j]",
        "      thickness_dz[idx] = thick_interp[j]",
        "      width_dz[idx] = width_interp[j]",
        "    endfor",
        "  endif",
        "endfor",
        "",
        "; 6. No need to handle no-data values",
        "",
        "; 7. Reference volume from horizontal grid (trapezoidal rule)",
        "total_volume_dx = 0.",
        "for i = 0, n_elements(thickness_dx)-2 do begin",
        "  avg_th = (thickness_dx[i] + thickness_dx[i+1]) / 2.",
        "  avg_w = (width_dx[i] + width_dx[i+1]) / 2.",
        "  total_volume_dx += avg_th * avg_w * dx",
        "endfor",
        "",
        "; 8. Prepare arrays for area and distance per band",
        "area_dz = dblarr(nb_dz)",
        "distance_per_band_dz = dblarr(nb_dz)",
        "",
        "; 9. Map each elevation band to its distance along glacier and compute area",
        "for i = 0, nb_dz-1 do begin",
        "  elev_target = surface_dz[i]",
        "  x_interp = interpol(distance_dx, surface_dx, elev_target)",
        "  ; Calculate distance step by looking at neighboring elevations",
        "  if i eq 0 then begin",
        "    if nb_dz gt 1 then begin",
        "      next_elev = surface_dz[1]",
        "      next_x = interpol(distance_dx, surface_dx, next_elev)",
        "      distance_step = abs(next_x - x_interp)",
        "    endif else distance_step = dx",
        "  endif else if i eq nb_dz-1 then begin",
        "    prev_elev = surface_dz[nb_dz-2]",
        "    prev_x = interpol(distance_dx, surface_dx, prev_elev)",
        "    distance_step = abs(x_interp - prev_x)",
        "  endif else begin",
        "    prev_elev = surface_dz[i-1]",
        "    next_elev = surface_dz[i+1]",
        "    prev_x = interpol(distance_dx, surface_dx, prev_elev)",
        "    next_x = interpol(distance_dx, surface_dx, next_elev)",
        "    distance_step = abs(next_x - prev_x) / 2.0",
        "  endelse",
        "  distance_per_band_dz[i] = distance_step",
        "  area_dz[i] = width_dz[i] * distance_step / 1000.0  ; km²",
        "endfor",
        "",
        "distance_per_band_dz[0] = distance_per_band_dz[1]  ; Ensure first element is not zero",
        "",
        "; 10. Calculate vertical grid volume and error",
        "total_volume_dz = total(thickness_dz * area_dz * 1000.)  ; m³",
        "volume_error = abs(total_volume_dx - total_volume_dz) / total_volume_dx * 100.0  ; volume error in percent",
        "",
        "print, 'Reference volume: ', total_volume_dx, ' m³'",
        "print, 'Vertical grid volume: ', total_volume_dz, ' m³'",
        "print, 'Volume error: ', volume_error, ' %'"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "Reference volume:        14212207. m³",
                "Vertical grid volume:        14188021. m³",
                "Volume error:       0.17017497 %",
                ""
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "; ========== CUMULATIVE DISTANCE ALONG VERTICAL GRID ==========",
        "",
        "; Start with the first band distance",
        "distance_dz = [distance_per_band_dz[0]/1000.0]",
        "for i = 1, n_elements(surface_dz)-1 do begin",
        "  distance_dz = [distance_dz, distance_dz[i-1] + distance_per_band_dz[i]/1000.0]",
        "endfor",
        "",
        "; rescale distance_dz to match the horizontal grid length",
        "distance_dz = distance_dz * (max(distance_dx) / max(distance_dz))",
        "distance_dz = distance_dz/1000.0  ; convert to km"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; ========== PLOT GLACIER PROFILE FROM VERTICAL GRID (ALL BANDS) ==========",
        "",
        "; Calculate bed elevation",
        "bed_elev_dz = surface_dz - thickness_dz",
        "",
        "; Create a window for the plot",
        "w2 = window(dimensions = [800, 600], background_color='white')",
        "",
        "; Plot bed elevation",
        "bed_plot = plot(distance_dz, bed_elev_dz, color='brown', thick=2, $",
        "    xrange=[min(distance_dz), max(distance_dz)], $",
        "    yrange=[min(bed_elev_dz), max(surface_dz)], $",
        "    xtitle='Distance along glacier (km)', ytitle='Elevation (m)', $",
        "    title='Glacier Profile After Horizontal-to-Vertical Grid Conversion: ' + glacier_id,$",
        "    /current)",
        "",
        "; Fill area under bed elevation with very light gray",
        "bed_x_poly = [distance_dz, reverse(distance_dz)]",
        "bed_y_poly = [replicate(min(bed_elev_dz)-100, n_elements(distance_dz)), reverse(bed_elev_dz)]",
        "p_bed = polygon(bed_x_poly, bed_y_poly, /fill_background, fill_color=[230,230,230], /data, target=w2)",
        "",
        "; Overlay glacier surface",
        "surface_plot = plot(distance_dz, surface_dz, color='blue', thick=2, /overplot)",
        "",
        "; Fill glacier area",
        "glacier_x = [distance_dz, reverse(distance_dz)]",
        "glacier_y = [bed_elev_dz, reverse(surface_dz)]",
        "p_glacier = polygon(glacier_x, glacier_y, /fill_background, fill_color=[180,220,255], /data, target=w2)",
        ""
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":800,\"ysize\":600,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "; ========== PLOT: DIRECT COMPARISON OF GLACIER PROFILES ==========",
        "",
        "w5 = window(dimensions = [800, 600], background_color='white')",
        "",
        "; Plot original (horizontal grid) glacier profile",
        "p1 = plot(x, surface_dx, color='blue', thick=2, $",
        "    yrange=[min([min(bed_dx), min(bed_elev_dz)]), max([max(surface_dx), max(surface_dz)])], $",
        "    xrange=[min(x), max(x)], $",
        "    xtitle='Distance along glacier (km)', ytitle='Elevation (m)', $",
        "    title='Direct Comparison: Glacier Profiles (Horizontal vs Vertical Grid)', $",
        "    /current, NAME='surface_dx')",
        "",
        "; Overlay bed for horizontal grid",
        "p2 = plot(x, bed_dx, color='brown', thick=2, /overplot, NAME='bed_dx')",
        "",
        "; Overlay vertical grid glacier surface",
        "p3 = plot(distance_dz, surface_dz, color='red', thick=2, linestyle=2, /overplot, NAME='surface_dz')",
        "",
        "; Overlay bed for vertical grid",
        "p4 = plot(distance_dz, bed_elev_dz, color='orange', thick=2, linestyle=2, /overplot, NAME='bed_dz')",
        "",
        "; Add legend",
        "leg = legend(target=[p1, p2, p3, p4], $",
        "    position=[max(distance_dz)*0.6, max([max(surface_dx), max(surface_dz)])*0.95], /data, /auto_text_color)"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":800,\"ysize\":600,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "; ========== Plots to check mass conservation ==========",
        "",
        "; Thickness of horizontally equidistant grid vs. vertically equidistant grid",
        "w3 = window(dimensions = [800, 600], background_color='white')",
        "",
        "; Plot thickness profiles: horizontal (x, thickness_dx) and vertical (x_cum, thickness_dz)",
        "p1 = plot(x, thickness_dx, color='red', thick=2, $",
        "    yrange=[0, max([max(thickness_dx), max(thickness_dz)]) * 1.1], $",
        "    xtitle='Distance along glacier (km)', ytitle='Thickness (m)', $",
        "    title='Thickness Profiles: Horizontal vs Vertical Grid', $",
        "    /current, NAME = 'thickness_dx')",
        "",
        "; Overlay vertical grid thickness",
        "p2 = plot(distance_dz, thickness_dz, color='blue', $",
        "    yrange=[0, max([max(thickness_dx), max(thickness_dz)]) * 1.1], $",
        "    xrange=[min(distance_dz), max(distance_dz)], $",
        "    thick=2, linestyle=2, /overplot, NAME = 'thickness_dz')",
        "",
        "; Add legend",
        "leg = legend(target=[p1, p2], position=[max(distance_dz)*0.95, max([max(thickness_dx), max(thickness_dz)])*0.95], $",
        "    /data, /auto_text_color)",
        ""
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":800,\"ysize\":600,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "; ========== MASS CONSERVATIVE VOLUME CORRECTION (VERTICAL GRID) ==========",
        "",
        "; Calculate current volume",
        "current_volume = total(thickness_dz * area_dz * 1000.)",
        "volume_error = abs(total_volume_dx - current_volume) / total_volume_dx",
        "",
        "; Save pre-correction thickness",
        "thickness_dz_before = thickness_dz",
        "",
        "; Apply thickness correction proportional to local thickness if error > 0.05%",
        "if volume_error gt 0.0005 then begin",
        "  print, 'Applying proportional thickness correction due to volume error: ', volume_error * 100., '%'",
        "  ; Calculate total thickness sum for weighting (only where thickness > 0 and area > 0)",
        "  valid = where((thickness_dz gt 0) and (area_dz gt 0), n_valid) ; only bands with ice",
        "  if n_valid gt 0 then begin",
        "    total_thick = total(thickness_dz[valid])",
        "    for i = 0, n_elements(thickness_dz)-1 do begin",
        "      if (thickness_dz[i] gt 0) and (area_dz[i] gt 0) then begin",
        "        weight = thickness_dz[i] / total_thick",
        "        ; Correction only for valid bands, avoid division by zero",
        "        thickness_dz[i] = thickness_dz[i] + (total_volume_dx - current_volume) / (area_dz[i] * 1000.) * weight",
        "      endif",
        "    endfor",
        "  endif",
        "endif",
        "; Final volume check",
        "final_volume = total(thickness_dz * area_dz * 1000.)",
        "final_error = abs(total_volume_dx - final_volume) / total_volume_dx",
        "",
        "print, 'Reference volume: ', total_volume_dx, ' m³'",
        "print, 'Final volume: ', final_volume, ' m³'",
        "print, 'Final volume error: ', final_error * 100., '%'"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "Applying proportional thickness correction due to volume error:       0.17017497",
                "%",
                "Reference volume:        14212207. m³",
                "Final volume:        14212207. m³",
                "Final volume error:        0.0000000%"
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "; ========== Plot: Corrected vs. Pre-correction Thickness (Vertical Grid) ==========",
        "",
        "w4 = window(dimensions = [800, 600], background_color='white')",
        "",
        "p1 = plot(distance_dz, thickness_dz_before, color='red', thick=5, $",
        "    xtitle='Surface Elevation (m)', ytitle='Thickness (m)', $",
        "    yrange=[0, max([max(thickness_dz_before), max(thickness_dz)])], $",
        "    title='Vertical Grid: Thickness Before vs After Correction', $",
        "    /current, NAME='thickness_dz_before')",
        "",
        "p2 = plot(distance_dz, thickness_dz, color='blue', thick=5, linestyle=2, /overplot, NAME='thickness_dz_after')",
        "",
        "leg = legend(target=[p1, p2], $",
        "    position=[min(distance_dz)*100, max([max(thickness_dz_before), max(thickness_dz)])*0.8], $",
        "    /data, /auto_text_color)",
        ""
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":800,\"ysize\":600,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    }
  ]
}