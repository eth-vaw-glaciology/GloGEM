    {
      "type": "markdown",
      "content": [
        "## 8. Visualise Simulated Glacier Geometry",
        "Plot the bed and evolved surface elevation for a chosen model year, with the glacier area filled for clarity."
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; Choose the year to plot (e.g., 25th year)",
        "year_to_plot = 1",
        "",
        "; x-axis: glacier length in km",
        "x_km = x / 1000.0",
        "",
        "; Extract geometry for the chosen year from geometry_history",
        "sur = reform(geometry_history[0, *, 0, year_to_plot])",
        "thick = reform(geometry_history[0, *, 1, year_to_plot])",
        "width_surface = reform(geometry_history[0, *, 2, year_to_plot])",
        "width_base = reform(geometry_history[0, *, 3, year_to_plot])",
        "width_mid = reform(geometry_history[0, *, 4, year_to_plot])",
        "x_km = reform(x_km)",
        "bed_dx = reform(bed_dx)",
        "",
        "; Create a window for the plot",
        "w = window(dimensions = [800, 600], background_color='white')",
        "",
        "; Plot bed elevation",
        "bed_plot = plot(x_km, bed_dx, color='brown', thick=2, $",
        "  yrange=[min(bed_dx), max(sur)], $",
        "  xrange=[min(x_km), max(x_km)], $",
        "  xtitle='Distance along glacier (km)', ytitle='Elevation (m)', $",
        "  title='Glacier Geometry at Year ' + strtrim(year_to_plot,2), $",
        "  /current)",
        "",
        "; Fill area under bed elevation",
        "bed_x = [x_km, reverse(x_km)]",
        "bed_y = [replicate(min(bed_dx)-100, n_elements(x_km)), reverse(bed_dx)]",
        "p_bed = polygon(bed_x, bed_y, /fill_background, fill_color=[230,230,230], /data, target=w)",
        "",
        "; Overlay glacier surface",
        "surface_plot = plot(x_km, sur, color='blue', thick=2, /overplot)",
        "",
        "; Optionally fill glacier area",
        "glacier_x = [x_km, reverse(x_km)]",
        "glacier_y = [bed_dx, reverse(sur)]",
        "p = polygon(glacier_x, glacier_y, /fill_background, fill_color=[180,220,255], /data, target=w)",
        ""
      ],
