    {
      "type": "code",
      "content": [
        "; ========== MASS CONSERVATIVE VOLUME CORRECTION ==========",
        "; Calculate current volume error",
        "current_volume = total(thick_new * area_new * 1000.)",
        "volume_error = abs(total_volume_flow - current_volume) / total_volume_flow",
        "",
        "; Apply weighted correction if error > 0.1%",
        "if volume_error gt 0.001 then begin",
        "  volume_correction_factor = total_volume_flow / current_volume",
        "  ice_bands = where(thick_new gt 0, n_ice_bands)",
        "  ",
        "  if n_ice_bands gt 0 then begin",
        "    total_distance_ice = total(distance_per_band[ice_bands])",
        "    ",
        "    if total_distance_ice gt 0 then begin",
        "      ; Apply distance-weighted thickness correction",
        "      for i = 0, n_ice_bands-1 do begin",
        "        band_idx = ice_bands[i]",
        "        distance_weight = distance_per_band[band_idx] / total_distance_ice",
        "        local_correction = 1.0 + (volume_correction_factor - 1.0) * distance_weight * n_ice_bands",
        "        ",
        "        ; Conservative limits",
        "        local_correction = local_correction > 0.7 < 1.5",
        "        thick_new[band_idx] = thick_new[band_idx] * local_correction",
        "      endfor",
        "    endif",
        "  endif",
        "endif",
        "",
        "; Final volume check",
        "final_volume = total(thick_new * area_new * 1000.)",
        "final_error = abs(total_volume_flow - final_volume) / total_volume_flow",
        "",
        "print, 'Reference volume: ', total_volume_flow, ' m³'",
        "print, 'Final volume: ', final_volume, ' m³'",
        "print, 'Final volume error: ', final_error * 100., '%'",
        "print, 'Volume correction: ', volume_error*100., '% -> ', final_error*100., '%'"
      ],
      "metadata": {},
