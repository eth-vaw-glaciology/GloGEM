    {
      "type": "code",
      "content": [
        "; ========== CREATE VERTICAL GRID ==========",
        "print, ''",
        "print, '=== CREATING VERTICAL GRID ==='",
        "",
        "; Vertical grid parameters",
        "step = 25.0  ; 25m elevation bands",
        "elev_min = min(sur_x)  ; Minimum surface elevation",
        "elev_max = max(sur_x)",
        "nb = fix((elev_max - elev_min) / step) + 1",
        "elev = elev_min + findgen(nb) * step",
        "",
        "; Initialize vertical arrays",
        "thick = dblarr(nb)",
        "area = dblarr(nb)",
        "width = dblarr(nb)",
        "gl = dblarr(nb)",
        "bed_elev = elev - 100.0  ; Initialize with some thickness",
        "noval = -9999.0",
        "",
        "print, 'Vertical grid created:'",
        "print, '  Bands: ', nb",
        "print, '  Elevation range: ', min(elev), ' to ', max(elev), ' m'",
        "print, '  Band size: ', step, ' m'",
        ""
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "",
                "=== CREATING VERTICAL GRID ===",
                "Vertical grid created:",
                "  Bands:           50",
                "  Elevation range:        1500.0000 to        2725.0000 m",
                "  Band size:       25.0000 m",
                ""
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
