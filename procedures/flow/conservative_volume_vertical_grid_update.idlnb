    {
      "type": "markdown",
      "content": [
        "### conservative_volume_vertical_grid_update",
        "This notebook is to test the back conversion from the horizontally equidistant grid to the vertically equidistant grid"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; ========== CREATE ARTIFICIAL GLACIER DATA ==========",
        "print, '=== CREATING ARTIFICIAL GLACIER DATA ==='",
        "",
        "; Horizontal grid parameters",
        "xnum = 50",
        "x_dist = findgen(xnum) * 500.0  ; 500m spacing, 25km total length",
        "dx = x_dist[1] - x_dist[0]  ; Constant spacing",
        "",
        "; Create realistic glacier profile",
        "bed_x = 1500.0 + x_dist * 0.05  ; Gentle upward bed slope",
        "th_x = dblarr(xnum)",
        "",
        "; Create realistic thickness profile (thick in middle, thin at ends)",
        "for i = 0, xnum-1 do begin",
        "  ; Parabolic thickness profile",
        "  relative_pos = float(i) / (xnum-1)  ; 0 to 1",
        "  if relative_pos le 0.1 then begin",
        "    ; Thin near terminus",
        "    th_x[i] = 50.0 * relative_pos / 0.1",
        "  endif else if relative_pos ge 0.9 then begin",
        "    ; Thin near head",
        "    th_x[i] = 50.0 * (1.0 - relative_pos) / 0.1",
        "  endif else begin",
        "    ; Thick in middle (parabolic)",
        "    mid_factor = 4.0 * (relative_pos - 0.1) * (0.9 - relative_pos) / (0.8^2)",
        "    th_x[i] = 50.0 + 200.0 * mid_factor",
        "  endelse",
        "endfor",
        "",
        "; Calculate surface elevation",
        "sur_x = bed_x + th_x",
        "",
        "; Create width profile (wider in middle)",
        "width_base = 100.0 + 300.0 * sin(!pi * findgen(xnum) / (xnum-1))",
        "lambda_x = dblarr(xnum) + 2.0  ; Constant shape factor",
        "width_surface_original = width_base + lambda_x * th_x",
        "",
        "print, 'Horizontal grid created:'",
        "print, '  Points: ', xnum",
        "print, '  Length: ', max(x_dist) - min(x_dist), ' m'",
        "print, '  Elevation range: ', min(sur_x), ' to ', max(sur_x), ' m'",
        "print, '  Max thickness: ', max(th_x), ' m'",
        "print, '  Width range: ', min(width_surface_original), ' to ', max(width_surface_original), ' m'"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
