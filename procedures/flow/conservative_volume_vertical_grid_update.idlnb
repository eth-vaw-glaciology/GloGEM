    {
      "type": "code",
      "content": [
        "; ; ========== CORRECTED INTERPOLATION WITH DISTANCE SAMPLING ==========",
        "; print, ''",
        "; print, '=== CORRECTED INTERPOLATION (DISTANCE SAMPLING) ==='",
        "",
        "; ; Calculate volume on vertical grid by finding distance represented by each elevation band",
        "; thick_new = dblarr(nb)",
        "; width_new = dblarr(nb)",
        "; area_new = dblarr(nb)",
        "; distance_per_band = dblarr(nb)",
        "",
        "; thick_new[valid_bands] = thick_interp",
        "; width_new[valid_bands] = width_interp",
        "",
        "; ; KEY FIX: Calculate actual distance represented by each elevation band",
        "; for i = 0, n_elements(valid_bands)-1 do begin",
        ";   band_idx = valid_bands[i]",
        ";   elev_target = elev_bands[band_idx]",
        "  ",
        ";   ; Find the distance range that corresponds to this elevation band",
        ";   elev_band_min = elev_target - step/2.0",
        ";   elev_band_max = elev_target + step/2.0",
        "  ",
        ";   ; Find all horizontal points within this elevation band",
        ";   points_in_band = where((sur_x ge elev_band_min) and (sur_x le elev_band_max), n_points_in_band)",
        "  ",
        ";   if n_points_in_band gt 0 then begin",
        ";     ; Calculate the distance range covered by this elevation band",
        ";     x_min_in_band = min(x_dist[points_in_band])",
        ";     x_max_in_band = max(x_dist[points_in_band])",
        ";     distance_covered = x_max_in_band - x_min_in_band",
        "    ",
        ";     ; For single points, use interpolation to estimate distance coverage",
        ";     if distance_covered eq 0 and n_points_in_band eq 1 then begin",
        ";       ; Estimate distance coverage by looking at neighboring elevation gradient",
        ";       point_idx = points_in_band[0]",
        "      ",
        ";       if point_idx gt 0 and point_idx lt n_elements(sur_x)-1 then begin",
        ";         ; Calculate local elevation gradient",
        ";         elev_grad = (sur_x[point_idx+1] - sur_x[point_idx-1]) / (x_dist[point_idx+1] - x_dist[point_idx-1])",
        ";         if abs(elev_grad) gt 0.001 then begin  ; Avoid division by zero",
        ";           distance_covered = step / abs(elev_grad)  ; Distance for this elevation step",
        ";         endif else begin",
        ";           distance_covered = dx  ; Use default distance step for flat areas",
        ";         endelse",
        ";       endif else begin",
        ";         distance_covered = dx  ; Use default for end points",
        ";       endelse",
        ";     endif",
        "    ",
        ";     ; Store the distance this band represents",
        ";     distance_per_band[band_idx] = distance_covered",
        "    ",
        ";     ; Calculate area using actual distance coverage",
        ";     area_new[band_idx] = width_new[band_idx] * distance_covered / 1000.0  ; Convert to km²",
        "    ",
        ";   endif else begin",
        ";     ; No points in this band - should not contribute to volume",
        ";     distance_per_band[band_idx] = 0.0",
        ";     area_new[band_idx] = 0.0",
        ";   endelse",
        "; endfor",
        "",
        "; total_volume_vertical_corrected = total(thick_new * area_new * 1000.)  ; Convert back to m³",
        "; volume_error_corrected = abs(total_volume_flow - total_volume_vertical_corrected) / total_volume_flow",
        "",
        "; print, ''",
        "; print, '=== CORRECTED VOLUME COMPARISON ==='",
        "; print, 'Reference volume: ', total_volume_flow, ' m³'",
        "; print, 'Corrected interpolated volume: ', total_volume_vertical_corrected, ' m³'",
        "; print, 'Corrected volume error: ', volume_error_corrected * 100., '%'",
        "",
        "; ; Diagnostic: Show distance coverage per elevation band",
        "; print, ''",
        "; print, 'Distance coverage per elevation band (first/last 5):'",
        "; for i = 0, 4 do begin",
        ";   band_idx = valid_bands[i]",
        ";   print, '  Band ', band_idx, ' (', elev_bands[band_idx], 'm): ', distance_per_band[band_idx], 'm distance'",
        "; endfor",
        "; print, '  ...'",
        "; for i = n_elements(valid_bands)-5, n_elements(valid_bands)-1 do begin",
        ";   band_idx = valid_bands[i]",
        ";   print, '  Band ', band_idx, ' (', elev_bands[band_idx], 'm): ', distance_per_band[band_idx], 'm distance'",
        "; endfor",
        "",
        "; print, 'Total distance covered: ', total(distance_per_band), 'm'",
        "; print, 'Original glacier length: ', (n_valid_flow-1) * dx, 'm'"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; ========== IMPROVED DISTANCE-BASED INTERPOLATION ==========",
        "print, ''",
        "print, '=== IMPROVED DISTANCE-BASED INTERPOLATION ==='",
        "",
        "; Calculate volume on vertical grid using continuous distance mapping",
        "thick_new = dblarr(nb)",
        "width_new = dblarr(nb)",
        "area_new = dblarr(nb)",
        "distance_per_band = dblarr(nb)",
        "",
        "thick_new[valid_bands] = thick_interp",
        "width_new[valid_bands] = width_interp",
        "",
        "; IMPROVED METHOD: Map each elevation band to its distance along glacier",
        "for i = 0, n_elements(valid_bands)-1 do begin",
        "  band_idx = valid_bands[i]",
        "  elev_target = elev_bands[band_idx]",
        "  ",
        "  ; Find the corresponding distance using interpolation",
        "  ; Interpolate x_dist based on surface elevation",
        "  if elev_target ge min(sur_x) and elev_target le max(sur_x) then begin",
        "    ; Find distance corresponding to this elevation",
        "    x_interp = interpol(x_dist, sur_x, elev_target)",
        "    ",
        "    ; Calculate distance step by looking at neighboring elevations",
        "    if i eq 0 then begin",
        "      ; First band - use distance to next band",
        "      if n_elements(valid_bands) gt 1 then begin",
        "        next_elev = elev_bands[valid_bands[1]]",
        "        if next_elev le max(sur_x) then begin",
        "          next_x = interpol(x_dist, sur_x, next_elev)",
        "          distance_step = abs(next_x - x_interp)",
        "        endif else begin",
        "          distance_step = dx  ; Default",
        "        endelse",
        "      endif else begin",
        "        distance_step = dx",
        "      endelse",
        "    endif else if i eq n_elements(valid_bands)-1 then begin",
        "      ; Last band - use distance from previous band",
        "      prev_elev = elev_bands[valid_bands[i-1]]",
        "      if prev_elev ge min(sur_x) then begin",
        "        prev_x = interpol(x_dist, sur_x, prev_elev)",
        "        distance_step = abs(x_interp - prev_x)",
        "      endif else begin",
        "        distance_step = dx",
        "      endelse",
        "    endif else begin",
        "      ; Middle bands - use average of distances to neighbors",
        "      prev_elev = elev_bands[valid_bands[i-1]]",
        "      next_elev = elev_bands[valid_bands[i+1]]",
        "      ",
        "      if prev_elev ge min(sur_x) and next_elev le max(sur_x) then begin",
        "        prev_x = interpol(x_dist, sur_x, prev_elev)",
        "        next_x = interpol(x_dist, sur_x, next_elev)",
        "        distance_step = abs(next_x - prev_x) / 2.0",
        "      endif else begin",
        "        distance_step = dx",
        "      endelse",
        "    endelse",
        "    ",
        "    ; Store the distance this band represents",
        "    distance_per_band[band_idx] = distance_step",
        "    ",
        "  endif else begin",
        "    ; Outside glacier range",
        "    distance_per_band[band_idx] = 0.0",
        "  endelse",
        "  ",
        "  ; Calculate area using actual distance coverage",
        "  area_new[band_idx] = width_new[band_idx] * distance_per_band[band_idx] / 1000.0  ; Convert to km²",
        "endfor",
        "",
        "total_volume_vertical_improved = total(thick_new * area_new * 1000.)  ; Convert back to m³",
        "volume_error_improved = abs(total_volume_flow - total_volume_vertical_improved) / total_volume_flow",
        "",
        "print, ''",
        "print, '=== IMPROVED VOLUME COMPARISON ==='",
        "print, 'Reference volume: ', total_volume_flow, ' m³'",
        "print, 'Improved interpolated volume: ', total_volume_vertical_improved, ' m³'",
        "print, 'Improved volume error: ', volume_error_improved * 100., '%'",
        "",
        "; Diagnostic: Show improved distance coverage",
        "print, ''",
        "print, 'Improved distance coverage per elevation band (first/last 5):'",
        "for i = 0, 4 do begin",
        "  band_idx = valid_bands[i]",
        "  print, '  Band ', band_idx, ' (', elev_bands[band_idx], 'm): ', distance_per_band[band_idx], 'm distance'",
        "endfor",
        "print, '  ...'",
        "for i = n_elements(valid_bands)-5, n_elements(valid_bands)-1 do begin",
        "  band_idx = valid_bands[i]",
        "  print, '  Band ', band_idx, ' (', elev_bands[band_idx], 'm): ', distance_per_band[band_idx], 'm distance'",
        "endfor",
        "",
        "print, 'Total distance covered (improved): ', total(distance_per_band), 'm'",
        "print, 'Original glacier length: ', (n_valid_flow-1) * dx, 'm'",
        "print, 'Distance coverage ratio: ', total(distance_per_band) / ((n_valid_flow-1) * dx) * 100., '%'"
      ],
      "metadata": {},
      "outputs": [
