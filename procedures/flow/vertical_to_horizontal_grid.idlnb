    {
      "type": "code",
      "content": [
        "; generate the bedrock in pre-frontal region (spacing = 125 m between points) by extrapolating the last 10 % of the glacier bedrock",
        "; prefrontal_elev = fltarr(extra_grids) ; initialize prefrontal elevation array",
        "",
        "upper_bound_index = round(0.1 * n_elements(sur_x)) ; index marking 10 % of the glacier grid ",
        "",
        "",
        "avg_slope = (bedrock_elev[0.1 * n_elements(sur_x)] - bedrock_elev[0]) / (0.1 * length_fixeddistance)",
        "lowest_bedrock_elev = bedrock_elev[0] ; lowest bedrock elevation ",
        "prefrontal_elev = lowest_bedrock_elev - (findgen(extra_grids) * avg_slope * dx) ; extrapolate bedrock elevation in prefrontal region",
        "prefrontal_elev = reverse(prefrontal_elev) ; reverse the order of the array to match the order of lowest to highest elevation",
        "avg_slope",
        "",
        "prefrontal_elev ; check results"
      ],
