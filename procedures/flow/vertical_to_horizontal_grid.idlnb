        "; Surface elevation in pre-frontal region:",
        "sur_concat = fltarr(extra_grids)",
        "for i = extra_grids - 1, 0, -1 do begin",
        "  distance_from_front = (extra_grids - i) * dx",
        "  ; Determine the surface elevation based on 'prefrontal_elev_final' array with interp1:",
        "  sur_concat[i] = interpol(prefrontal_elev, x_concat_new, distance_from_front)",
        "endfor"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; merge bedrock elevation with prefrontal region",
        "bed_x = [prefrontal_elev, bed_x]",
        "",
        "; extend all other arrays to match the size of the bedrock elevation array (& set to 0)",
        "n_prefrontal = n_elements(prefrontal_elev)",
        "x_input = [x, x_concat] ; extend x array",
        "",
        "sur_input = [sur_concat, sur_x] ; extend surface elevation array with NaNs",
        "width_input = [width_x[0] * fltarr(n_prefrontal), width_x] ; extend width array",
        "th_input = [th_x[0] * fltarr(n_prefrontal), th_x] ; extend thickness array"
      ],
