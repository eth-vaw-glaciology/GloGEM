{
  "version": "2.0.0",
  "cells": [
    {
      "type": "markdown",
      "content": [
        "### convert vertical to horizontally equidistant grid",
        "",
        "This idl notebook is meant to convert the vertically equidistant grid from GloGEM to a horizontally equidistant grid for GloGEMflow",
        "",
        "Horizontally equidistant elevation bin output data:",
        "- `sur input` - the current surface elevation of the ice",
        "- `th_input` - the ice thickness",
        "- `width_input` - glacier width",
        "- `x_input` - distance along glacier (x direction)",
        "- `dx` - size of grid points"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; load example data hypsometry data",
        "username = 'jabeer'",
        "fn = \"/Volumes/\"+username+\"/glogem/geometricdata/rgiv6/bands/bands_consensus2019/centraleurope/02244.dat\" ; if share mounted on local machine",
        "; fn = '/itet-stor/'+username+'/glogem/geometricdata/rgiv6/bands/bands_consensus2019/centraleurope/01450.dat'",
        "glacier_geom = import_glacier_geometry(fn)",
        "",
        "; parameters",
        "frontal_length = 1.0/4.0"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; glacier_geom[*,1]"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; ; Determine the original horizontal resolution in data Matthias (not equidistant, as is derived from elevation bands and slope between them!)",
        "length_glacier_geom = n_elements(glacier_geom[*, 0])",
        "dx_original = fltarr(length_glacier_geom)",
        "for i = 1, length_glacier_geom - 1 do begin",
        "dx_original[i] = glacier_geom[i, 6] - glacier_geom[i - 1, 6]",
        "endfor"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; Interpolation to a horizontally regular (i.e. equidistant) grid",
        "dx_bin = glacier_geom[*,6] ; bin size in x-direction",
        "gl_length = dx_bin[-1] ; total length of the glacier grid in x-direction (glacier length)",
        "",
        "elev_span = max(glacier_geom[*,1]) - min(glacier_geom[*,1])",
        "threshold = 100",
        "if elev_span lt threshold then begin",
        "    scale = ((threshold - elev_span) / threshold) + 1.0",
        "    dx = round(gl_length / (400 * scale))",
        "endif else begin",
        "    dx = round(gl_length / 100)",
        "endelse"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "dx"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "           8",
                ""
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "grid_cells = floor(glacier_geom[length_glacier_geom - 1, 6] / dx)"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "x = findgen(grid_cells) * dx + dx",
        "x"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "       8.0000000       16.000000       24.000000       32.000000       40.000000",
                "       48.000000       56.000000       64.000000       72.000000       80.000000",
                "       88.000000       96.000000       104.00000       112.00000       120.00000",
                "       128.00000       136.00000       144.00000       152.00000       160.00000",
                "       168.00000       176.00000       184.00000       192.00000       200.00000",
                "       208.00000       216.00000       224.00000       232.00000       240.00000",
                "       248.00000       256.00000       264.00000       272.00000       280.00000",
                "       288.00000       296.00000       304.00000       312.00000       320.00000",
                "       328.00000       336.00000       344.00000       352.00000       360.00000",
                "       368.00000       376.00000       384.00000       392.00000       400.00000",
                "       408.00000       416.00000       424.00000       432.00000       440.00000",
                "       448.00000       456.00000       464.00000       472.00000       480.00000",
                "       488.00000       496.00000       504.00000       512.00000       520.00000",
                "       528.00000       536.00000       544.00000       552.00000       560.00000",
                "       568.00000       576.00000       584.00000       592.00000       600.00000",
                "       608.00000       616.00000       624.00000       632.00000       640.00000",
                "       648.00000       656.00000       664.00000       672.00000       680.00000",
                "       688.00000       696.00000       704.00000       712.00000       720.00000",
                "       728.00000       736.00000       744.00000       752.00000       760.00000",
                "       768.00000"
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "; slope = glacier_geom[*, 7] ; slope in degrees",
        "; l_horizontal = dx_bin * cos(slope * !DTOR) ; horizontal length of the elevation band (m)"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "glacier_geom_lookup_x = glacier_geom[*, 6] ; Distance along the flowline (m)",
        "glacier_geom_lookup_sur = (glacier_geom[*, 1] + glacier_geom[*, 2]) / 2 ; Surface elevation (m)",
        "glacier_geom_lookup_width = glacier_geom[*, 5] ; Width (m)",
        "glacier_geom_lookup_th = glacier_geom[*, 4] ; Thickness (m)"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "i = where(glacier_geom_lookup_width eq 0, count) ; Remove elevation bands with no ice",
        "  if count gt 0 then begin",
        "    good_indices = where(glacier_geom_lookup_width ne 0)",
        "    glacier_geom_lookup_x = glacier_geom_lookup_x[good_indices]",
        "    glacier_geom_lookup_sur = glacier_geom_lookup_sur[good_indices]",
        "    glacier_geom_lookup_width = glacier_geom_lookup_width[good_indices]",
        "    glacier_geom_lookup_th = glacier_geom_lookup_th[good_indices]",
        "  endif"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "sur_x = interpol(glacier_geom_lookup_sur, glacier_geom_lookup_x, x)       ; Surface elevation (linear interpolation)",
        "width_x = interpol(glacier_geom_lookup_width, glacier_geom_lookup_x, x)   ; Width (linear interpolation)",
        "i = where(x lt glacier_geom_lookup_x[0], count)",
        "if count gt 0 then width_x[i] = glacier_geom_lookup_width[0]"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "th_x = interpol(glacier_geom_lookup_th, glacier_geom_lookup_x, x)",
        "i = where(x lt glacier_geom_lookup_x[0], count)",
        "if count gt 0 then th_x[i] = glacier_geom_lookup_th[0] ; Thickness for cells lower than first point on Huss grid: same as thickness first point Huss grid",
        "bed_x = sur_x - th_x"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; ; Check how much the volume and area have changed:",
        "volume_Huss_1d = total((glacier_geom[*, 3] * 1e6) * glacier_geom[*, 4])",
        "print, 'volume_Huss_1d = ', volume_Huss_1d",
        "volume_Huss_1d_fixeddistance = total(width_x * th_x * dx)",
        "print, 'volume_Huss_1d_fixeddistance = ', volume_Huss_1d_fixeddistance",
        "area_Huss_1d = total(glacier_geom[*, 3] * 1e6)",
        "print, 'area_Huss_1d = ', area_Huss_1d",
        "area_Huss_1d_fixeddistance = total(width_x * dx)",
        "print, 'area_Huss_1d_fixeddistance = ', area_Huss_1d_fixeddistance",
        "i = where(th_x gt 1, count)",
        "length_fixeddistance = count * dx"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "volume_Huss_1d =        12533219.",
                "volume_Huss_1d_fixeddistance =        27109094.",
                "area_Huss_1d =        346250.00",
                "area_Huss_1d_fixeddistance =        747687.59"
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "difference_volume = volume_Huss_1d_fixeddistance - volume_Huss_1d",
        "print, 'difference_volume = ', difference_volume",
        "print, 'difference_in_percentage = ', (difference_volume / volume_Huss_1d) * 100, '%'"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "difference_volume =        14575875.",
                "difference_in_percentage =        116.29794%",
                ""
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "; print area difference in percentage",
        "difference_area = area_Huss_1d_fixeddistance - area_Huss_1d",
        "print, 'difference_area = ', difference_area",
        "print, 'difference_area_in_percentage = ', (difference_area / area_Huss_1d) * 100, '%'"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "difference_area =        401437.59",
                "difference_area_in_percentage =        115.93865%",
                ""
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "; ; Add geometric information for parts lower than glacier at inventory date",
        "extra_grids = ceil((x[n_elements(x) - 1] * frontal_length) / dx) ; downstream of present-day glacier",
        "x_concat = findgen(extra_grids) * dx + x[n_elements(x) - 1] + dx ; will be placed upstream of present-day glacier",
        "th_concat = fltarr(extra_grids) ; downstream of present-day glacier",
        "width_concat = fltarr(extra_grids) ; downstream of present-day glacier"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; ; Check volume difference for elevation bins above 3000 m",
        "; i = where(sur_x gt 3000, count)",
        "; g = where(glacier_geom[*,1] gt 3000, count)",
        "; if count gt 0 then begin",
        ";   volume_Huss_1d_above_3000 = total((glacier_geom[g, 3] * 1e6) * glacier_geom[g, 4])",
        ";   print, 'volume_Huss_1d_above_3000 = ', volume_Huss_1d_above_3000",
        ";   volume_Huss_1d_fixeddistance_above_3000 = total(width_x[i] * th_x[i] * dx)",
        ";   print, 'volume_Huss_1d_fixeddistance_above_3000 = ', volume_Huss_1d_fixeddistance_above_3000",
        ";   difference_volume_above_3000 = volume_Huss_1d_fixeddistance_above_3000 - volume_Huss_1d_above_3000",
        ";   print, 'difference_volume_above_3000 = ', difference_volume_above_3000",
        ";   print, 'difference_in_percentage_above_3000 = ', (difference_volume_above_3000 / volume_Huss_1d_above_3000) * 100, '%'",
        "; endif"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; ; check volume difference for elevation bins below 3000 m",
        "; i = where(sur_x lt 3000, count)",
        "; g = where(glacier_geom[*,1] lt 3000, count)",
        "; if count gt 0 then begin",
        ";   volume_Huss_1d_below_3000 = total((glacier_geom[g, 3] * 1e6) * glacier_geom[g, 4])",
        ";   print, 'volume_Huss_1d_below_3000 = ', volume_Huss_1d_below_3000",
        ";   volume_Huss_1d_fixeddistance_below_3000 = total(width_x[i] * th_x[i] * dx)",
        ";   print, 'volume_Huss_1d_fixeddistance_below_3000 = ', volume_Huss_1d_fixeddistance_below_3000",
        ";   difference_volume_below_3000 = volume_Huss_1d_fixeddistance_below_3000 - volume_Huss_1d_below_3000",
        ";   print, 'difference_volume_below_3000 = ', difference_volume_below_3000",
        ";   print, 'difference_in_percentage_below_3000 = ', (difference_volume_below_3000 / volume_Huss_1d_below_3000) * 100, '%'",
        "; endif"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "extra_grids"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "          25",
                ""
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "; compute the bedrock elevation under the glacier",
        "bedrock_elev = dblarr(n_elements(sur_x)) ; initialize bedrock elevation array",
        "",
        "for i = 0, n_elements(x) - 1 do begin",
        "    ; if glacier_bed_elev is not available, use surface elevation minus thickness",
        "    bedrock_elev[i] = sur_x[i] - th_x[i]",
        "endfor"
      ],
      "metadata": {},
      "outputs": []
    },
