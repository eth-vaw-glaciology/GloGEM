{
  "version": "2.0.0",
  "cells": [
    {
      "type": "markdown",
      "content": [
        "# GloGEM Flow vs dhdt Comparison",
        "",
        "Compare the SIA flow model (Option A: flowline mass balance) with the dhdt parameterisation."
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "markdown",
      "content": [
        "## 1. Load Data",
        "",
        "Load both the flowline grid (flow version) and the elevation-band geometry (dhdt version)."
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "compile_opt idl2",
        "",
        "data_dir = 'results_glogemflow/r6_monthly/CentralEurope/'",
        "",
        "; Load flow model results (flowline grid with annual history)",
        "restore, data_dir + 'flowgrid_01450_flow.sav'",
        "flow = flow_hist",
        "",
        "; Load dhdt results (elevation band geometry)",
        "restore, data_dir + 'geometry_01450_dhdt.sav'",
        "dhdt = geometry_hist",
        "",
        "; Flow grid: distance from tongue in km",
        "dist_km = flow.dist_dx / 1000.0",
        "",
        "print, 'Flow grid: xnum=', flow.xnum, '  dx=', flow.dx, ' m'",
        "print, 'dhdt grid: nb=', dhdt.nb",
        "print, 'Years: ', min(flow.years), ' to ', max(flow.years)",
        "print, 'Flow volume 2004: ', flow.volume[54]",
        "print, 'dhdt volume 2004: ', dhdt.volume[54]"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "Flow grid: xnum=         125  dx=         200 m",
                "dhdt grid: nb=                   258",
                "Years:         1950 to         2100",
                "Flow volume 2004:        14.406177",
                "dhdt volume 2004:        13.712941"
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "markdown",
      "content": [
        "## 2. Volume Evolution"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "p = plot(flow.years, flow.volume, 'b-2', title='Volume Evolution', $",
        "  xtitle='Year', ytitle='Volume (km$^3$)', name='Flow (SIA)')",
        "p2 = plot(dhdt.years, dhdt.volume, 'r-2', /overplot, name='dhdt')",
        "l = legend(target=[p, p2], position=[0.35, 0.85])"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":640,\"ysize\":512,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "markdown",
      "content": [
        "## 3. Area Evolution"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "p = plot(flow.years, flow.area_total, 'b-2', title='Area Evolution', $",
        "  xtitle='Year', ytitle='Area (km$^2$)', name='Flow (SIA)')",
        "p2 = plot(dhdt.years, dhdt.area_total, 'r-2', /overplot, name='dhdt')",
        "l = legend(target=[p, p2], position=[0.35, 0.85])"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":640,\"ysize\":512,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "markdown",
      "content": [
        "## 4. Glacier-wide Mass Balance"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "p = plot(flow.years, flow.mb, 'b-2', title='Glacier-wide Mass Balance', $",
        "  xtitle='Year', ytitle='Mass Balance (m w.e./yr)', name='Flow (SIA)')",
        "p2 = plot(dhdt.years, dhdt.mb, 'r-2', /overplot, name='dhdt')",
        "p3 = plot([min(flow.years), max(flow.years)], [0, 0], 'k--1', /overplot)",
        "l = legend(target=[p, p2], position=[0.35, 0.85])"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":640,\"ysize\":512,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "markdown",
      "content": [
        "## 5. Surface Profiles Along Flowline",
        "",
        "Flow model profiles at different years. The x-axis is distance from the tongue (km)."
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; Surface profiles at selected years",
        "yrs_plot = [2004, 2020, 2050, 2080, 2100]",
        "colors = ['blue', 'green', 'orange', 'red', 'purple']",
        "",
        "; Bedrock profile",
        "p = plot(dist_km, flow.bed_dx, 'k-2', title='Surface Profiles (Flow Model)', $",
        "  xtitle='Distance from tongue (km)', ytitle='Elevation (m a.s.l.)', $",
        "  name='Bedrock', yrange=[1000, 4500], fill_color='tan', fill_level=0)",
        "",
        "; Array to store plot handles",
        "handles = [p]",
        "",
        "for k = 0, n_elements(yrs_plot)-1 do begin",
        "  iy = where(flow.years eq yrs_plot[k], cy)",
        "  if cy eq 0 then continue",
        "  iy = iy[0]",
        "  ii_ice = where(flow.thick[*, iy] gt 0, n_ice)",
        "  if n_ice eq 0 then continue",
        "  i_term = min(ii_ice)",
        "  i_head = max(ii_ice)",
        "  n_pts = n_ice + 2",
        "  x_prof = dblarr(n_pts)",
        "  y_prof = dblarr(n_pts)",
        "  x_prof[0] = dist_km[i_term]",
        "  y_prof[0] = flow.bed_dx[i_term]",
        "  for j = 0, n_ice-1 do begin",
        "    x_prof[j+1] = dist_km[ii_ice[j]]",
        "    y_prof[j+1] = flow.sur[ii_ice[j], iy]",
        "  endfor",
        "  x_prof[n_pts-1] = dist_km[i_head]",
        "  y_prof[n_pts-1] = flow.bed_dx[i_head]",
        "  p_s = plot(x_prof, y_prof, '-2', color=colors[k], /overplot, $",
        "    name=strtrim(yrs_plot[k],2))",
        "  handles = [handles, p_s]",
        "endfor",
        "",
        "l = legend(target=handles, /auto_text_color, position=[0.9, 0.9])",
        ""
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":640,\"ysize\":512,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "markdown",
      "content": [
        "## 6. Ice Thickness Along Flowline"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "yrs_plot = [2004, 2020, 2050, 2080, 2100]",
        "colors = ['blue', 'green', 'orange', 'red', 'purple']",
        "",
        "p = plot(dist_km, reform(flow.thick[*, 54]), 'b-2', $",
        "  title='Ice Thickness (Flow Model)', $",
        "  xtitle='Distance from tongue (km)', ytitle='Thickness (m)', $",
        "  name='2004')",
        "",
        "for k = 1, n_elements(yrs_plot)-1 do begin",
        "  iy = where(flow.years eq yrs_plot[k])",
        "  if iy[0] ge 0 then begin",
        "    pp = plot(dist_km, reform(flow.thick[*, iy[0]]), '-2', $",
        "      color=colors[k], /overplot, name=strtrim(yrs_plot[k], 2))",
        "  endif",
        "endfor",
        "l = legend(position=[0.85, 0.85])"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":640,\"ysize\":512,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "markdown",
      "content": [
        "## 7. Mass Balance Profile Along Flowline"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; Mass balance profile at 2020 and 2050",
        "iy20 = where(flow.years eq 2020)",
        "iy50 = where(flow.years eq 2050)",
        "",
        "p = plot(dist_km, reform(flow.bal[*, iy20[0]]), 'b-2', $",
        "  title='Mass Balance Profile', $",
        "  xtitle='Distance from tongue (km)', ytitle='Mass Balance (m w.e./yr)', $",
        "  name='2020')",
        "p2 = plot(dist_km, reform(flow.bal[*, iy50[0]]), 'r-2', /overplot, name='2050')",
        "p3 = plot([0, max(dist_km)], [0, 0], 'k--1', /overplot)",
        "l = legend(target=[p, p2], position=[0.85, 0.85])"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":640,\"ysize\":512,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "markdown",
      "content": [
        "## 8. Volume Change Rate (dV/dt)"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "; Compute dV/dt",
        "n = n_elements(flow.years)",
        "dvdt_flow = flow.volume[1:n-1] - flow.volume[0:n-2]",
        "dvdt_dhdt = dhdt.volume[1:n-1] - dhdt.volume[0:n-2]",
        "yrs_mid = flow.years[1:n-1]",
        "",
        "p = plot(yrs_mid, dvdt_flow, 'b-2', title='Volume Change Rate', $",
        "  xtitle='Year', ytitle='dV/dt (km$^3$/yr)', name='Flow (SIA)')",
        "p2 = plot(yrs_mid, dvdt_dhdt, 'r-2', /overplot, name='dhdt')",
        "p3 = plot([min(yrs_mid), max(yrs_mid)], [0, 0], 'k--1', /overplot)",
        "l = legend(target=[p, p2], position=[0.35, 0.85])"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":640,\"ysize\":512,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "markdown",
      "content": [
        "## 9. Summary Statistics"
      ],
      "metadata": {},
      "outputs": []
    },
    {
      "type": "code",
      "content": [
        "print, '=== Summary ==='",
        "print, ''",
        "yrs_check = [2004, 2020, 2050, 2100]",
        "print, 'Year    Flow_Vol   dhdt_Vol   Flow_Area  dhdt_Area  Flow_MB    dhdt_MB'",
        "for k = 0, n_elements(yrs_check)-1 do begin",
        "  iy = where(flow.years eq yrs_check[k])",
        "  if iy[0] ge 0 then begin",
        "    print, yrs_check[k], flow.volume[iy[0]], dhdt.volume[iy[0]], $",
        "      flow.area_total[iy[0]], dhdt.area_total[iy[0]], $",
        "      flow.mb[iy[0]], dhdt.mb[iy[0]]",
        "  endif",
        "endfor"
      ],
      "metadata": {},
      "outputs": [
        {
          "items": [
            {
              "mime": "text/plain",
              "content": [
                "=== Summary ===",
                "",
                "Year    Flow_Vol   dhdt_Vol   Flow_Area  dhdt_Area  Flow_MB    dhdt_MB",
                "        2004       14.406177       13.712941       79.760117       80.962907",
                "     -0.17766963     -0.43324953",
                "        2020       12.991350       12.026811       78.165192       77.181907",
                "     -0.17466609     -0.33138103",
                "        2050       9.6425078       9.0019983       72.465814       69.082647",
                "      -2.8452083      -3.4388738",
                "        2100       5.5402747       4.2875755       62.874215       52.759959",
                "     -0.26025683      -1.2419091",
                ""
              ]
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    }
  ]
}