    {
      "type": "code",
      "content": [
        "; Select the time index you want to plot",
        "i = 1",
        "",
        "; x-axis: glacier length in km",
        "x = length[*, i]  ; length is in km",
        "",
        "; Glacier surface elevation at time index i",
        "surface_elev = elev[*, i]      ; surface elevation",
        "bed = bed_elev[*, i]           ; bed elevation (assumed static)",
        "",
        "; Get the year for the selected index",
        "year = years[i]",
        "",
        "; Create a window for the plot",
        "w1 = window(dimensions = [800, 600], background_color='white')",
        "",
        "; Plot bed elevation",
        "bed_plot = plot(x, bed, color='brown', thick=2, $",
        "    yrange=[min(bed), max(surface_elev)], $",
        "    xtitle='Distance along glacier (km)', ytitle='Elevation (m)', $",
        "    title= rgi_id + ' at year ' + strtrim(year, 2) + ' (' + scenario + ')', $",
        "    /current)",
        "",
        "; Fill area under bed elevation with very light gray",
        "bed_x = [x, reverse(x)]",
        "bed_y = [replicate(min(bed)-100, n_elements(x)), reverse(bed)]",
        "p_bed = polygon(bed_x, bed_y, /fill_background, fill_color=[230,230,230], /data, target=w1)",
        "",
        "; Overlay glacier surface",
        "surface_plot = plot(x, surface_elev, color='blue', thick=2, /overplot)",
        "",
        "; Optional: fill glacier area",
        "glacier_x = [x, reverse(x)]",
        "glacier_y = [bed, reverse(surface_elev)]",
        "p = polygon(glacier_x, glacier_y, /fill_background, fill_color=[180,220,255], /data, target=w1)",
        "",
        "; save the plot as a PNG file",
        "file_name = file_expand_path(fig_dir + rgi_id + '_profile_' + scenario + '_' + strtrim(year,2) + '.png')",
        "w1.save, file_name, /png",
        "",
        "; Use thickness_dx, width_dx, surface_dx, distance_dx for horizontal grid",
        "; Use thickness_dz, width_dz, area_dz, surface_dz, distance_per_band_dz, elevation_dz for vertical grid"
