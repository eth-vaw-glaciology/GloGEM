          "items": [
            {
              "mime": "idl/notebook-renderer",
              "content": "{\"type\":\"idlnotebookimage_png\",\"item\":{\"xsize\":800,\"ysize\":600,\"data\":\"\"}}"
            }
          ],
          "metadata": {
            "id": "not-saved"
          }
        }
      ]
    },
    {
      "type": "code",
      "content": [
        "; Plot total ice volume evolution over time",
        "",
        "; Calculate total ice volume at each time step",
        "; Assume thick_dx is thickness [m] at each grid point and width_dx is width [m] at each grid point",
        "; distance_dx is the length [km] of each grid cell, so convert to meters",
        "; total_volume = sum over all grid points: thickness * width * distance",
        "",
        "n_time = n_elements(years)",
        "total_volume = dblarr(n_time)",
        "",
        "FOR i=0, n_time-1 DO BEGIN",
        "    ; For each time step, sum the volume along the glacier",
        "    ; thick_dx[*,i], width_dx[*,i], distance_dx[*,i]",
        "    ; distance_dx is in km, convert to meters",
        "    cell_volume = thick_dx[*,i] * width_dx[*,i] * (dist_dx * 1000.0)",
        "    total_volume[i] = total(cell_volume, /nan)",
        "ENDFOR",
        "",
        "; Convert volume to km^3 for plotting",
        "total_volume_km3 = total_volume / 1e9",
        "",
        "; Plot the volume evolution",
        "w2 = window(dimensions=[700,400], background_color='white')",
        "volume_plot = plot(years, total_volume_km3, color='navy', thick=2, $",
        "    xtitle='Year', ytitle='Total Ice Volume (km!U3!N)', $",
        "    title=rgi_id + ' - Total Ice Volume Evolution (' + scenario + ')', $",
        "    /current)",
        "",
        "; Save the plot as PNG",
        "file_name = file_expand_path(fig_dir + rgi_id + '_volume_evolution_' + scenario + '.png')",
        "w2.save, file_name, /png"
      ],
